function tabDrop(e,id){
  e.preventDefault();
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('tab-drag-over'));
  if(!tabDragSrc||tabDragSrc===id)return;
  const from=S.tabOrder.indexOf(tabDragSrc),to=S.tabOrder.indexOf(id);
