// ── multi-select / bulk ───────────────────────────────────────────────────
function rowClick(e,id,visIds){
  if(['INPUT','SELECT','TEXTAREA','BUTTON'].includes(e.target.tagName))return;
  const idx=visIds.indexOf(id);
  if(e.shiftKey&&lastSelIdx!==null){
    const lo=Math.min(lastSelIdx,idx),hi=Math.max(lastSelIdx,idx);
    for(let i=lo;i<=hi;i++)selectedIds.add(visIds[i]);
  }else{
    selectedIds.has(id)?selectedIds.delete(id):selectedIds.add(id);
  }
  lastSelIdx=idx;renderAll();
}
function toggleCheck(id,checked,visIds){
  checked?selectedIds.add(id):selectedIds.delete(id);
  lastSelIdx=visIds.indexOf(id);renderAll();
}
function toggleAll(checked,visIds){
  visIds.forEach(id=>checked?selectedIds.add(id):selectedIds.delete(id));renderAll();
}
function deleteSelected(){
  if(!selectedIds.size)return;
  if(!confirm(`確定刪除選取的 ${selectedIds.size} 筆？`))return;
  S.rows=S.rows.filter(r=>!selectedIds.has(r.id));
  toast(`已刪除 ${selectedIds.size} 筆`,'🗑');selectedIds.clear();save();renderAll();
}
function applyBulk(){
  const field=document.getElementById('bField').value;
  let value='';
  if(field==='vendor')value=(document.getElementById('bVendorSel')||{}).value||'';
  else if(field==='zone')value=(document.getElementById('bZoneSel')||{}).value||'';
  else if(field==='manager')value=(document.getElementById('bMgrSel')||{}).value||'';
  else value=(document.getElementById('bText')||{}).value||'';
  if(!field){toast('請選擇欄位','⚠️');return;}
  // date bulk with validation
  if(field==='planIn'){
    let skipCount=0;
    selectedIds.forEach(id=>{
      const r=S.rows.find(x=>x.id===id);if(!r)return;
      if(value&&r.planDone&&value>r.planDone){toast(`#${id} 進場日期不可晚於完成日期，跳過`,'⚠️');skipCount++;return;}
      r.planIn=value;
      if(value&&!r.planDone)r.planDone=value;
    });
  } else if(field==='actualIn'){
    selectedIds.forEach(id=>{
      const r=S.rows.find(x=>x.id===id);if(!r)return;
      if(value&&r.actualDone&&value>r.actualDone){toast(`#${id} 實際進場不可晚於實際完成，跳過`,'⚠️');return;}
      r.actualIn=value;
    });
  } else if(field==='planDone'){
    selectedIds.forEach(id=>{
      const r=S.rows.find(x=>x.id===id);if(!r)return;
      if(value&&r.planIn&&value<r.planIn){toast(`#${id} 完成日期不可早於進場日期，跳過`,'⚠️');return;}
      r.planDone=value;
    });
  } else if(field==='actualDone'){
    selectedIds.forEach(id=>{
      const r=S.rows.find(x=>x.id===id);if(!r)return;
      if(value&&r.actualIn&&value<r.actualIn){toast(`#${id} 實際完成不可早於實際進場，跳過`,'⚠️');return;}
      r.actualDone=value;
    });
  } else {
    selectedIds.forEach(id=>{const r=S.rows.find(x=>x.id===id);if(r)r[field]=value;});
  }
  toast(`已批次更新 ${selectedIds.size} 筆`,'✏️');save();renderAll();
}
function wireBulk(){
  const sel=document.getElementById('bField');if(!sel)return;
  const showEl=(id,show)=>{const e=document.getElementById(id);if(e)e.style.display=show?'':'none';};
  sel.onchange=()=>{
    const v=sel.value;
    showEl('bVendorSel',v==='vendor');
    showEl('bZoneSel',v==='zone');
    showEl('bMgrSel',v==='manager');
    showEl('bText',['floor','unit'].includes(v));
    showEl('bDateIn',['planIn','actualIn'].includes(v));
    showEl('bDateDone',['planDone','actualDone'].includes(v));
  };
  // Live conflict check on bulk date inputs
  function checkBulkDateConflict(){
    const field=sel.value;
    const dateIn=document.getElementById('bDateIn'),dateDone=document.getElementById('bDateDone');
    const val=(dateDone&&dateDone.style.display!=='none')?dateDone.value:(dateIn?dateIn.value:'');
    if(!val||!field){
      if(dateIn)dateIn.style.cssText=dateIn.style.cssText.replace(/;?color:[^;]+/,'').replace(/;?border-color:[^;]+/,'');
      if(dateDone)dateDone.style.cssText=dateDone.style.cssText.replace(/;?color:[^;]+/,'').replace(/;?border-color:[^;]+/,'');
      return;
    }
    let hasConflict=false;
    if(field==='planDone'||field==='actualDone'){
      const inField=field==='planDone'?'planIn':'actualIn';
      selectedIds.forEach(id=>{const r=S.rows.find(x=>x.id===id);if(r&&r[inField]&&val<r[inField])hasConflict=true;});
      const el=dateDone;
      if(el){el.style.color=hasConflict?'var(--red)':'';el.style.borderColor=hasConflict?'var(--red)':'';}
    } else if(field==='planIn'||field==='actualIn'){
      const doneField=field==='planIn'?'planDone':'actualDone';
      selectedIds.forEach(id=>{const r=S.rows.find(x=>x.id===id);if(r&&r[doneField]&&val>r[doneField])hasConflict=true;});
      const el=dateIn;
      if(el){el.style.color=hasConflict?'var(--red)':'';el.style.borderColor=hasConflict?'var(--red)':'';}
    }
  }
  const bDateIn=document.getElementById('bDateIn'),bDateDone=document.getElementById('bDateDone');
  if(bDateIn){bDateIn.onchange=()=>{checkBulkDateConflict();};}
  if(bDateDone){bDateDone.onchange=()=>{checkBulkDateConflict();};}
}

