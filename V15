<script type="module">
// ════════════════════════════════════════════════════════
//  FIREBASE CONFIG — 請把下方換成你的 Firebase 專案設定
// ════════════════════════════════════════════════════════
import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js';
import { getFirestore, doc, setDoc, onSnapshot, getDoc }
  from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js';

const FIREBASE_CONFIG = {
  apiKey:            "AIzaSyA4xrql0AZTPOK16SAsAp8oYi3ltb-i6U0",
  authDomain:        "g95-work.firebaseapp.com",
  projectId:         "g95-work",
  storageBucket:     "g95-work.firebasestorage.app",
  messagingSenderId: "518379622669",
  appId:             "1:518379622669:web:1deb196d0c5d57872e6044"
};
const DB_DOC = 'projects/main';   // Firestore 文件路徑（可自訂）

// ── 初始化 ────────────────────────────────────────────────────
const app  = initializeApp(FIREBASE_CONFIG);
const db   = getFirestore(app);
const ref  = doc(db, DB_DOC);

// ── 把函式掛到 window，讓主程式可以呼叫 ──────────────────────
window._fbSave = async function(data){
  try{
    await setDoc(ref, { payload: JSON.stringify(data) }, { merge: true });
  } catch(e){ console.error('[Firebase] save error', e); }
};

window._fbListen = function(onChange){
  return onSnapshot(ref, snap => {
    if(!snap.exists()) return;
    try{
      const d = JSON.parse(snap.data().payload);
      if(d && d.rows) onChange(d);
    } catch(e){ console.error('[Firebase] parse error', e); }
  });
};

window._fbLoad = async function(){
  try{
    const snap = await getDoc(ref);
    if(!snap.exists()) return null;
    return JSON.parse(snap.data().payload);
  } catch(e){ console.error('[Firebase] load error', e); return null; }
};

// ── 通知主程式 Firebase 已就緒 ────────────────────────────────
window._fbReady = true;
document.dispatchEvent(new Event('firebase-ready'));
</script>

