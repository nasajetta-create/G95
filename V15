<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>工程缺失追蹤系統</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#6B6F72;--surface:#F4F2EF;--card:#fff;--border:#D0CEC9;--border2:#E8E6E2;
  --text:#1E1D1B;--text2:#5F5E5A;--text3:#9A9896;
  --purple:#3C3489;--green:#2E6B26;--green-lt:#EAF6E7;
  --red:#A32D2D;--red-lt:#FFF0F0;--amber:#7A4200;--amber-lt:#FFF4E0;
  --blue:#185FA5;--blue-lt:#EBF4FF;
  --font:'Noto Sans TC',sans-serif;--r:10px;--rs:6px;
}
body{font-family:var(--font);background:var(--bg);color:var(--text);font-size:13px;min-height:100vh}
.shell{max-width:1700px;margin:0 auto;padding:14px}
.page-hdr{color:#fff;font-size:19px;font-weight:700;letter-spacing:.04em;margin-bottom:12px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.page-hdr span{font-size:12px;font-weight:400;opacity:.65}
.card{border-radius:14px;padding:16px;transition:box-shadow .3s}
.card-main  {background:#F0EEF8;box-shadow:0 2px 14px rgba(60,52,137,.13)}
.card-main:hover{box-shadow:0 8px 32px rgba(60,52,137,.22)}
.card-vendor{background:#EEF6F0;box-shadow:0 2px 14px rgba(15,110,86,.11)}
.card-vendor:hover{box-shadow:0 8px 32px rgba(15,110,86,.22)}
.card-warn  {background:#FFF5EE;box-shadow:0 2px 14px rgba(163,45,45,.11)}
.card-warn:hover{box-shadow:0 8px 32px rgba(163,45,45,.22)}
.card-cal   {background:#EEF4FF;box-shadow:0 2px 14px rgba(24,95,165,.11)}
.card-cal:hover{box-shadow:0 8px 32px rgba(24,95,165,.22)}
.card-zones {background:#FFFAEE;box-shadow:0 2px 14px rgba(122,66,0,.11)}
.card-zones:hover{box-shadow:0 8px 32px rgba(122,66,0,.22)}
.card-mgr   {background:#FFF0F8;box-shadow:0 2px 14px rgba(122,0,85,.11)}
.card-mgr:hover{box-shadow:0 8px 32px rgba(122,0,85,.22)}

.tabs{display:flex;flex-wrap:wrap;border-bottom:1.5px solid var(--border);margin-bottom:14px}
.tab{padding:8px 13px;font-size:12px;font-weight:500;cursor:pointer;border:none;background:none;color:var(--text2);border-bottom:2.5px solid transparent;margin-bottom:-1.5px;font-family:var(--font);white-space:nowrap;transition:color .15s;user-select:none}
.tab:hover{color:var(--text)}.tab.active{color:var(--purple);border-bottom-color:var(--purple)}

/* ── Alert / Event tables ─────────────────────────── */
.ae-tbl{width:100%;border-collapse:collapse;font-size:12px;margin-top:8px}
.ae-tbl th{background:#ECEAE6;font-size:11px;font-weight:600;color:var(--text2);padding:6px 7px;text-align:left;border-bottom:1px solid var(--border);white-space:nowrap}
.ae-tbl td{padding:5px 6px;border-bottom:1px solid var(--border2);vertical-align:middle}
.ae-tbl tr:last-child td{border-bottom:none}
.ae-tbl tr:hover td{background:rgba(0,0,0,.02)}
.ae-tbl input[type=text],.ae-tbl textarea{width:100%;font-size:11px;padding:3px 5px;border:1px solid var(--border);border-radius:4px;font-family:var(--font);outline:none;background:var(--card)}
.ae-tbl input[type=text]:focus,.ae-tbl textarea:focus{border-color:var(--purple)}
.ae-tbl textarea{min-height:34px;resize:vertical}
.ae-tbl input[type=date]{font-size:11px;padding:3px 5px;border:1px solid var(--border);border-radius:4px;font-family:var(--font);outline:none;background:var(--card);color:var(--text)}
.ae-tbl input[type=date]:focus{border-color:var(--purple)}
.ae-tbl select{width:100%;font-size:11px;padding:3px 5px;border:1px solid var(--border);border-radius:4px;font-family:var(--font);outline:none;background:var(--card)}
.ae-sec{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:12px 14px;margin-bottom:14px}
.ae-sec-hdr{display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap}
.ae-sec-title{font-size:13px;font-weight:700;flex:1}
.ae-done-date{color:var(--green);font-weight:600}
.ae-overdue{color:var(--red);font-weight:600}
.ae-id{color:var(--text3);font-size:10px;text-align:center;width:24px}
.card-event{background:#F0F4FF;box-shadow:0 2px 14px rgba(24,95,165,.13)}
.card-done{background:#EAF6E7;box-shadow:0 2px 14px rgba(46,107,38,.13)}
.card-done:hover{box-shadow:0 8px 32px rgba(46,107,38,.22)}
.card-event:hover{box-shadow:0 8px 32px rgba(24,95,165,.22)}


/* ── Progress bar ─────────────────────────────────────── */
.prog-wrap{margin-top:5px;background:#E8E6E2;border-radius:4px;height:7px;overflow:hidden}
.prog-bar{height:7px;border-radius:4px;transition:width .4s}
.prog-lbl{font-size:10px;color:var(--text2);margin-top:2px;text-align:right}

/* ── PDF import button ─────────────────────────────────── */
.btn-pdf-import{background:#E8E0F8;color:#3C3489;border:1px solid #C4B8F0}
.btn-pdf-import:hover{background:#D8CCF4}

/* drag tabs */
.tab.tab-drag-over{border-bottom:2.5px solid var(--amber)!important}

.bar{display:flex;gap:7px;align-items:center;flex-wrap:wrap;margin-bottom:12px}
.bar select{font-size:12px;padding:6px 9px;border:1px solid var(--border);border-radius:var(--rs);background:var(--card);color:var(--text);font-family:var(--font);outline:none}
.bar select:focus{border-color:var(--purple)}
.btn{font-size:12px;padding:6px 12px;border:1px solid var(--border);border-radius:var(--rs);background:var(--card);color:var(--text);cursor:pointer;font-family:var(--font);white-space:nowrap;transition:all .18s}
.btn:hover{background:var(--border2);transform:translateY(-1px);box-shadow:0 2px 8px rgba(0,0,0,.1)}
.btn-p{background:var(--purple)!important;color:#fff!important;border-color:var(--purple)!important;font-weight:500}
.btn-p:hover{background:#2a2460!important}
.btn-d{background:var(--red-lt)!important;color:var(--red)!important;border-color:#ffcaca!important}
.btn-pdf{background:#fff3e0!important;color:#a34200!important;border-color:#f5c07a!important}
.btn-g{background:var(--green-lt)!important;color:var(--green)!important;border-color:#b5d9ae!important}
.btn-sm{padding:3px 8px!important;font-size:11px!important}

.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(90px,1fr));gap:7px;margin-bottom:12px}
.stat{background:rgba(255,255,255,.65);border-radius:var(--rs);padding:.6rem .85rem;border:1px solid rgba(255,255,255,.9)}
.stat-l{font-size:10px;color:var(--text2);margin-bottom:2px;font-weight:500;letter-spacing:.04em}
.stat-v{font-size:21px;font-weight:700}

.bulk-bar{display:none;align-items:center;gap:8px;flex-wrap:wrap;background:rgba(60,52,137,.08);border:1px solid rgba(60,52,137,.2);border-radius:var(--rs);padding:8px 12px;margin-bottom:10px;font-size:12px}
.bulk-bar.show{display:flex}
.bulk-bar select,.bulk-bar input[type=text],.bulk-bar input[type=date]{font-size:12px;padding:5px 8px;border:1px solid var(--border);border-radius:var(--rs);font-family:var(--font);outline:none;background:var(--card)}

.tbl-wrap{overflow-x:auto;border:1px solid var(--border);border-radius:var(--r);background:var(--card);box-shadow:0 1px 6px rgba(0,0,0,.07)}
table{width:100%;border-collapse:collapse;font-size:11px}
thead th{background:#ECEAE6;font-weight:600;font-size:10px;color:var(--text2);padding:7px 4px;text-align:left;border-bottom:1px solid var(--border);white-space:nowrap;vertical-align:bottom}
thead th.th-chk{width:26px;text-align:center}
thead th.th-date{white-space:normal;line-height:1.3}
tbody tr{border-bottom:1px solid var(--border2);transition:background .08s}
tbody tr:last-child{border-bottom:none}
tbody tr:hover td{background:rgba(60,52,137,.04)!important}
tbody tr.r-over td{background:#FFF0F0!important}
tbody tr.r-w3 td{background:#FFF4E0!important}
tbody tr.r-w7 td{background:#EBF4FF!important}
tbody tr.r-done td{background:#EAF6E7!important}
tbody tr.row-sel td{background:rgba(60,52,137,.1)!important;outline:1px solid var(--purple)}
td{padding:4px 4px;vertical-align:top;overflow:hidden}
td.td-txt{white-space:pre-wrap;word-break:break-all;min-width:90px;max-width:220px}
td.td-issue{white-space:pre-wrap;word-break:break-all;min-width:100px;max-width:240px}
td input[type=text],td textarea,td select{font-size:11px;padding:3px 4px;border:1px solid var(--border);border-radius:3px;background:var(--card);color:var(--text);font-family:var(--font);width:100%;outline:none}
td input[type=text]:focus,td select:focus,td textarea:focus{border-color:var(--purple);box-shadow:0 0 0 2px rgba(60,52,137,.08)}
td input[type=date]{font-size:10px;padding:2px 3px;border:1px solid var(--border);border-radius:3px;width:auto;background:var(--card);color:var(--text);min-width:0}
td input[type=date]:focus{border-color:var(--purple)}
td input[type=checkbox]{width:14px;height:14px;cursor:pointer;accent-color:var(--purple)}
td textarea{resize:vertical;min-height:32px;line-height:1.5}
.dow-lbl{font-size:10px;color:var(--purple);font-weight:600;margin-left:4px;white-space:nowrap}
.date-wrap{display:flex;align-items:center;flex-wrap:nowrap;gap:2px;margin-bottom:3px}
.date-pre{font-size:9px;font-weight:700;color:var(--text3);width:18px;flex-shrink:0}
.date-pre.plan{color:#185FA5}.date-pre.actual{color:#2E6B26}

.dot{width:9px;height:9px;border-radius:50%;display:inline-block;flex-shrink:0}
.badge{display:inline-block;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:600;white-space:nowrap}
.bdone{background:var(--green-lt);color:var(--green)}.bover{background:var(--red-lt);color:var(--red)}
.b3{background:var(--amber-lt);color:var(--amber)}.b7{background:var(--blue-lt);color:var(--blue)}
.del-btn{background:none;border:none;cursor:pointer;color:var(--text3);padding:2px 3px;border-radius:3px;font-size:13px;line-height:1}
.del-btn:hover{color:var(--red);background:var(--red-lt)}
.empty{text-align:center;padding:2rem;color:var(--text3);font-size:12px}

#toast-wrap{position:fixed;top:14px;right:14px;z-index:9999;display:flex;flex-direction:column;gap:6px;pointer-events:none}
.toast{display:flex;align-items:center;gap:8px;background:var(--purple);color:#fff;border-radius:var(--rs);padding:9px 15px;font-size:12px;font-weight:500;box-shadow:0 4px 18px rgba(0,0,0,.22);animation:tIn .2s ease;max-width:320px}
@keyframes tIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:translateX(0)}}

/* modal */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:8000;align-items:center;justify-content:center}
.modal-bg.show{display:flex}
.modal{background:var(--card);border-radius:14px;padding:22px 24px;min-width:300px;max-width:420px;width:90%;box-shadow:0 8px 40px rgba(0,0,0,.2)}
.modal h3{font-size:14px;font-weight:700;margin-bottom:14px;color:var(--text)}
.modal input[type=text]{width:100%;font-size:13px;padding:8px 10px;border:1px solid var(--border);border-radius:var(--rs);font-family:var(--font);outline:none;margin-bottom:12px}
.modal input[type=text]:focus{border-color:var(--purple)}
.modal .modal-btns{display:flex;gap:8px;justify-content:flex-end}

.sec{border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:10px;box-shadow:0 1px 5px rgba(0,0,0,.07);transition:box-shadow .2s}
.sec:hover{box-shadow:0 5px 18px rgba(0,0,0,.12)}
.sec-hdr{padding:8px 14px;font-size:12px;font-weight:600;display:flex;align-items:center;gap:8px;justify-content:space-between}
.sec-hdr-l{display:flex;align-items:center;gap:8px}

.vcards{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:9px;margin-bottom:12px}
.vc{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:11px 13px;cursor:pointer;transition:all .18s}
.vc:hover{border-color:#888;transform:translateY(-2px);box-shadow:0 5px 14px rgba(0,0,0,.1)}
.vc.sel{border:2px solid var(--purple);box-shadow:0 0 0 3px rgba(60,52,137,.12)}
.vc-name{font-size:12px;font-weight:600;margin-bottom:7px;display:flex;align-items:center;gap:5px}
.vc-row{display:flex;justify-content:space-between;font-size:11px;padding:2px 0;border-bottom:1px solid var(--border2)}
.vc-row:last-child{border-bottom:none}

.side-editor{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:13px;width:230px;flex-shrink:0;box-shadow:0 1px 5px rgba(0,0,0,.07)}
/* drag-sortable list */
.ed-list{list-style:none}
.ed-item{display:flex;align-items:center;gap:6px;padding:5px 0;border-bottom:1px solid var(--border2);cursor:default}
.ed-item:last-child{border-bottom:none}
.ed-item.drag-over{border-top:2px solid var(--purple)}
.drag-handle{cursor:grab;color:var(--text3);font-size:14px;flex-shrink:0;user-select:none;padding:0 2px}
.drag-handle:active{cursor:grabbing}

.ztab{padding:7px 14px;font-size:12px;border:1px solid var(--border);border-radius:20px;cursor:pointer;background:var(--card);color:var(--text2);font-family:var(--font);font-weight:500;transition:all .15s}
.ztab:hover{border-color:#888;transform:translateY(-1px)}
.ztab.active{color:#fff;border-color:transparent;font-weight:600}
.zs-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:9px;margin-bottom:14px}
.zs-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:11px 13px;border-left:4px solid transparent;cursor:pointer;transition:all .18s}
.zs-card:hover{transform:translateY(-2px);box-shadow:0 5px 14px rgba(0,0,0,.1)}
.zs-card.sel{box-shadow:0 0 0 2px var(--purple)}
.zs-title{font-size:12px;font-weight:600;margin-bottom:7px}
.zs-row{display:flex;justify-content:space-between;font-size:11px;padding:2px 0;border-bottom:1px solid var(--border2)}
.zs-row:last-child{border-bottom:none}

.cal-nav{display:flex;align-items:center;justify-content:space-between;padding:9px 13px;background:#ECEAE6;border-bottom:1px solid var(--border)}
.cal-lbl{font-size:13px;font-weight:600}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr)}
.cal-dow{text-align:center;font-size:10px;font-weight:600;color:var(--text2);padding:5px 0;background:var(--surface);border-bottom:1px solid var(--border2)}
.cal-dow.wknd{color:var(--red)}
.cal-cell{min-height:90px;border-right:1px solid var(--border2);border-bottom:1px solid var(--border2);padding:4px;background:var(--card);vertical-align:top;transition:background .12s}
.cal-cell:hover{background:#F6F4FF}
.cal-cell:nth-child(7n){border-right:none}
.cal-cell.today-c{background:#F0EEFF}
.cal-cell.wknd-c{background:#FAFAF8}
.cal-dnum{font-size:10px;font-weight:600;margin-bottom:2px;line-height:1.3}
.cal-dnum.today-n{background:var(--purple);color:#fff;border-radius:50%;width:19px;height:19px;display:flex;align-items:center;justify-content:center;font-size:9px}
.cal-ev{font-size:9px;padding:1px 3px;border-radius:2px;margin-bottom:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.5}
.ev-in{background:#B5D4F4;color:#042C53}
.ev-done{background:#C0DD97;color:#173404}
.ev-ad{background:#CECBF6;color:#26215C}
.cal-legend{display:flex;gap:10px;flex-wrap:wrap;font-size:11px;color:var(--text2);padding:7px 13px;border-bottom:1px solid var(--border2)}
.ldot{width:9px;height:9px;border-radius:2px;display:inline-block;margin-right:3px;vertical-align:middle}
.import-drop{border:2px dashed var(--border);border-radius:var(--r);padding:14px;text-align:center;color:var(--text2);font-size:12px;cursor:pointer;transition:all .15s;margin-bottom:12px}
.import-drop:hover,.import-drop.drag{border-color:var(--purple);background:rgba(60,52,137,.04)}
.share-bar{background:#EAF0FF;border:1px solid #B0C4EE;border-radius:var(--rs);padding:9px 13px;font-size:12px;color:#1a3a6e;margin-bottom:12px;display:flex;align-items:center;gap:9px;flex-wrap:wrap}
@media print{
  body{background:#fff}.shell{padding:0}
  .page-hdr,.tabs,.bar,.del-btn,.btn-pdf,.btn-p,.side-editor,#toast-wrap,.no-print,.modal-bg{display:none!important}
  .card{box-shadow:none;padding:0}.tbl-wrap{box-shadow:none;border:1px solid #ccc}
}
@media(max-width:700px){.stats{grid-template-columns:repeat(3,1fr)}.side-editor{width:100%}.cal-cell{min-height:55px}.cal-ev{font-size:8px}}
</style>

