      +'<td>'+esc(ev.content)+'</td>'
      +'<td>'+fmtMD(ev.contractStart)+'</td>'
      +'<td style="'+(overdue?'color:#A32D2D;font-weight:600':'')+'">'+fmtMD(ev.contractEnd)+'</td>'
      +'<td>'+fmtMD(ev.actualStart)+'</td>'
      +'<td style="'+(isDone?'color:#2E6B26;font-weight:600':'')+'">'+fmtMD(ev.actualEnd)+'</td>'
      +'</tr>';
  }).join('');
  const body='<table><thead><tr><th>#</th><th>管理人</th><th>對應單位</th><th>區域位置</th><th>內容說明</th><th>合約預定開始</th><th>合約預定完成</th><th>實際開始</th><th>實際完成</th></tr></thead><tbody>'+rows+'</tbody></table>';
  printSection('事件紀錄',body);
}


// ── PANE: Done ────────────────────────────────────────────────────────────
function printDoneTable(){printSection('已完成工作',pdfTable(S.completed,true));}
function restoreRow(compId){
  const c=S.completed.find(x=>x.compId===compId);
  if(!c)return;
  if(!confirm('確定將此項目移回追蹤總表？'))return;
  const {compId:_c,completedAt:_a,...row}=c;
  S.rows.push(row);
  S.completed=S.completed.filter(x=>x.compId!==compId);
  save();renderAll();toast('已移回追蹤總表');
}
function delCompleted(compId){
  if(!confirm('確定永久刪除此完成記錄？'))return;
  S.completed=S.completed.filter(x=>x.compId!==compId);
  save();renderDone();toast('已刪除','🗑');
}
function renderDone(){
  const data=S.completed.slice().sort((a,b)=>{
    const da=a.completedAt||'',db=b.completedAt||'';
    return db.localeCompare(da); // 最新完成在前
  });
  // 統計
  const total=data.length;
  const byVendor={};
  data.forEach(r=>{const v=r.vendor||'未指定';if(!byVendor[v])byVendor[v]=0;byVendor[v]++;});
  // 表格（格式同 tblHTML）
  const rows=data.map(r=>{
    return '<tr class="r-done">'
      +'<td style="padding:4px 6px;text-align:center;font-size:10px;color:var(--text3)">'+r.id+'</td>'
      +'<td style="padding:4px 6px">'+esc(r.manager||'—')+'</td>'
      +'<td style="padding:4px 6px"><span style="font-size:10px;padding:2px 5px;border-radius:8px;background:'+zColor(r.zone)+'22;color:'+zColor(r.zone)+'">'+esc(zLabel(r.zone))+'</span></td>'
      +'<td style="padding:4px 6px">'+esc(r.unit)+'</td>'
      +'<td style="padding:4px 6px;text-align:center">'+esc(r.floor)+'</td>'
      +'<td style="padding:4px 6px"><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:'+vColor(r.vendor||'')+';margin-right:4px"></span>'+esc(r.vendor||'—')+'</td>'
      +'<td style="padding:4px 6px">'+esc(r.issue)+'</td>'
      +'<td style="padding:4px 6px;color:var(--text2)">'+esc(r.note||'')+'</td>'
      +'<td style="vertical-align:top;padding:3px 4px">'
        +'<div class="date-wrap"><span class="date-pre plan">預</span><input type="date" value="'+esc(r.planIn)+'" disabled style="width:110px;background:#f9f9f9;color:var(--text2)"><span class="dow-lbl">'+dowStr(r.planIn)+'</span></div>'
        +'<div class="date-wrap" style="margin-top:2px"><span class="date-pre actual">實</span><input type="date" value="'+esc(r.actualIn)+'" disabled style="width:110px;background:#f9f9f9;color:var(--text2)"><span class="dow-lbl">'+dowStr(r.actualIn)+'</span></div>'
      +'</td>'
      +'<td style="vertical-align:top;padding:3px 4px">'
        +'<div class="date-wrap"><span class="date-pre plan">預</span><input type="date" value="'+esc(r.planDone)+'" disabled style="width:110px;background:#f9f9f9;color:var(--text2)"><span class="dow-lbl">'+dowStr(r.planDone)+'</span></div>'
        +'<div class="date-wrap" style="margin-top:2px"><span class="date-pre actual">實</span><input type="date" value="'+esc(r.actualDone)+'" disabled style="width:110px;color:var(--green);font-weight:600;background:#f9f9f9"><span class="dow-lbl">'+dowStr(r.actualDone)+'</span></div>'
      +'</td>'
      +'<td style="padding:4px 6px;text-align:center"><span class="badge bdone">完成</span></td>'
      +'<td style="padding:4px 6px;text-align:center;font-size:10px;color:var(--text3)">'+esc(r.completedAt||'')+'</td>'
      +'<td style="padding:4px 6px;text-align:center;white-space:nowrap">'
        +'<button class="btn btn-sm no-print" onclick="restoreRow('+r.compId+')" title="移回追蹤總表" style="font-size:10px;padding:2px 6px">↩ 還原</button> '
        +'<button class="btn btn-d btn-sm no-print" onclick="delCompleted('+r.compId+')" title="刪除" style="font-size:10px;padding:2px 6px">🗑</button>'
      +'</td>'
      +'</tr>';
  }).join('');
  const empty=!data.length?'<tr><td colspan="13" style="text-align:center;padding:18px;color:var(--text3)">尚無已完成項目</td></tr>':'';
  document.getElementById('pane-done').innerHTML=
    '<div class="ae-sec">'
    +'<div class="ae-sec-hdr">'
    +'<span style="font-size:16px">✅</span>'
    +'<span class="ae-sec-title">已完成工作</span>'
    +'<div style="display:flex;gap:7px;flex-wrap:wrap;margin-left:auto">'
    +'<div class="stat"><div class="stat-l">總完成</div><div class="stat-v" style="color:var(--green)">'+total+'</div></div>'
    +'</div>'
    +'</div>'
    +'<div class="bar no-print">'
    +'<button class="btn btn-pdf" onclick="printDoneTable()">🖨 PDF</button>'
    +'</div>'
    +'<div style="overflow-x:auto"><table class="tbl" style="font-size:12px">'
    +'<thead><tr>'
    +'<th>#</th><th>管理人</th><th>區域</th><th>戶別</th><th>樓層</th><th>廠商</th><th>缺失內容</th><th>備註</th>'
    +'<th>進場日期<br><span style="font-weight:400;color:var(--text3)">預/實</span></th>'
    +'<th>完成日期<br><span style="font-weight:400;color:var(--text3)">預/實</span></th>'
    +'<th>狀態</th><th>完成於</th><th class="no-print">操作</th>'
    +'</tr></thead>'
    +'<tbody>'+rows+empty+'</tbody>'
    +'</table></div>'
    +'</div>';
}

// ── Tabs ──────────────────────────────────────────────────────────────────
const TAB_DEFS={
  main:  {label:'📋 追蹤總表'},
  vendor:{label:'🏢 廠商分類'},
  warn:  {label:'⚠️ 預警看板'},
  cal:   {label:'📅 雙週行事曆'},
  zones: {label:'🗂 分區表單'},
  mgr:   {label:'👤 管理人員'},
  events:{label:'📌 事件紀錄'},
  done:  {label:'✅ 已完成工作'},
};
function renderTabBar(){
  const order=S.tabOrder.filter(id=>TAB_DEFS[id]);
  document.getElementById('tab-bar').innerHTML=order.map(id=>`
    <button class="tab${id===activeTab?' active':''}" data-id="${id}"
      draggable="true"
      ondragstart="tabDragStart(event,'${id}')"
      ondragover="tabDragOver(event,'${id}')"
      ondrop="tabDrop(event,'${id}')"
      ondragleave="document.querySelectorAll('.tab').forEach(t=>t.classList.remove('tab-drag-over'))"
      onclick="switchTab('${id}')">${TAB_DEFS[id].label}</button>`).join('');
}
function switchTab(id){
  activeTab=id;
  const mc=document.getElementById('mainCard');
  mc.className='card '+(TAB_BG[id]||'card-main');
  Object.keys(TAB_DEFS).forEach(t=>document.getElementById('pane-'+t).style.display=t===id?'':'none');
  renderTabBar();renderPane(id);
}
function renderPane(id){
  if(id==='main')renderMain();
  if(id==='vendor')renderVendor();
  if(id==='warn')renderWarn();
  if(id==='cal')renderCal();
  if(id==='zones')renderZones();
  if(id==='mgr')renderMgr();
  if(id==='events')renderEvents();
  if(id==='done')renderDone();
}
function renderAll(){renderPane(activeTab);}

// ── init ──────────────────────────────────────────────────────────────────
async function init(){
  Object.keys(TAB_DEFS).forEach(t=>{if(t!=='main')document.getElementById('pane-'+t).style.display='none';});
  renderTabBar();renderMain();   // 先用 localStorage 畫出 UI
  await load();                  // 再從 Firebase 更新（async）
  renderTabBar();renderAll();
  startFirebaseListen();
}

// 若 Firebase module 已分派 ready 事件，直接啟動；否則等最多 3 秒
if(window._fbReady){
  init();
} else {
  const _initTimer=setTimeout(()=>{
    setSyncStatus('offline');
    init();
  }, 3000);
  document.addEventListener('firebase-ready',()=>{
    clearTimeout(_initTimer);
    init();
  },{once:true});
  // 先用 localStorage 畫出初始畫面，不讓使用者等白畫面
  Object.keys(TAB_DEFS).forEach(t=>{if(t!=='main')document.getElementById('pane-'+t).style.display='none';});
  try{const s=localStorage.getItem(SK);if(s){const d=JSON.parse(s);if(d&&d.rows)S=migrateState(d);}}catch(e){}
  renderTabBar();renderMain();
}
</script>
</body>
</html>
