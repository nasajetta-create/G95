}

// ── Excel import ──────────────────────────────────────────────────────────
const FMAP={
  '管理人':'manager','戶別':'unit','樓層':'floor','廠商':'vendor',
  '缺失內容':'issue','備註':'note','備註說明':'note',
  '預計進場':'planIn','預計完成':'planDone','實際進場':'actualIn','實際完成':'actualDone','區域':'zone_label'
};
function excelToISO(v){
  if(typeof v==='number'){
    const d=new Date(Math.round((v-25569)*86400000));
    return`${d.getUTCFullYear()}-${String(d.getUTCMonth()+1).padStart(2,'0')}-${String(d.getUTCDate()).padStart(2,'0')}`;
  }
  if(typeof v==='string'){
    const s=v.trim();
    let m;
    m=s.match(/^(\d{4})[\/.\-](\d{1,2})[\/.\-](\d{1,2})/);
    if(m)return`${m[1]}-${m[2].padStart(2,'0')}-${m[3].padStart(2,'0')}`;
    m=s.match(/^(\d{1,2})[\/.\-](\d{1,2})[\/.\-](\d{4})/);
    if(m)return`${m[3]}-${m[1].padStart(2,'0')}-${m[2].padStart(2,'0')}`;
    m=s.match(/^(\d{4})(\d{2})(\d{2})$/);
    if(m)return`${m[1]}-${m[2]}-${m[3]}`;
  }
  return'';
}
function importExcel(file){
  const rd=new FileReader();
  rd.onload=e=>{
    try{
      const wb=XLSX.read(e.target.result,{type:'array',cellDates:false,raw:true});
      const wsName=wb.SheetNames.find(n=>n.includes('追蹤')||n.includes('缺失'))||wb.SheetNames[0];
      const raw=XLSX.utils.sheet_to_json(wb.Sheets[wsName],{defval:'',raw:true});
      if(!raw.length){toast('Excel無有效資料','⚠️');return;}
      let added=0,skipped=0;
      raw.forEach(row=>{
        const mapped={};
        Object.entries(row).forEach(([k,rawVal])=>{
          const fk=FMAP[k.trim()];if(!fk)return;
          if(['planIn','planDone','actualIn','actualDone'].includes(fk))mapped[fk]=excelToISO(rawVal);
          else mapped[fk]=String(rawVal||'').trim();
        });
        if(!mapped.issue&&!mapped.unit){skipped++;return;}
        // auto-add vendor
        if(mapped.vendor&&!S.vendors.includes(mapped.vendor)){S.vendors.push(mapped.vendor);toast(`已自動新增廠商：${mapped.vendor}`,'🏢');}
        // auto-add manager
        if(mapped.manager&&!S.managers.includes(mapped.manager)){S.managers.push(mapped.manager);toast(`已自動新增管理人：${mapped.manager}`,'👤');}
        let zone=S.zones[0]?S.zones[0].id:'indoor';
        if(mapped.zone_label){
          const zn=S.zones.find(z=>z.label===mapped.zone_label||mapped.zone_label.includes(z.label.replace(/\s/g,'')));
          if(zn){zone=zn.id;}
          else{
            // 自動新增分區
            const newZoneId='z'+Date.now()+'_'+Math.random().toString(36).slice(2,6);
            const newColor=V_COLORS[S.zones.length%V_COLORS.length];
            S.zones.push({id:newZoneId,label:mapped.zone_label,color:newColor});
            zone=newZoneId;
            toast('已自動新增分區：'+mapped.zone_label,'📁');
          }
        }
        // enforce date order
        if(mapped.planIn&&mapped.planDone&&mapped.planDone<mapped.planIn)mapped.planDone=mapped.planIn;
        if(mapped.actualIn&&mapped.actualDone&&mapped.actualDone<mapped.actualIn)mapped.actualDone=mapped.actualIn;
        if(mapped.planIn&&!mapped.planDone)mapped.planDone=mapped.planIn;
        S.rows.push({id:S.nextId++,zone,manager:mapped.manager||'',unit:mapped.unit||'',floor:mapped.floor||'',
          vendor:mapped.vendor||S.vendors[0]||'',issue:mapped.issue||'',note:mapped.note||'',
          planIn:mapped.planIn||'',planDone:mapped.planDone||'',actualIn:mapped.actualIn||'',actualDone:mapped.actualDone||''});
        added++;
      });
      toast(`匯入完成：新增 ${added} 筆，略過 ${skipped} 筆`,'📊');save();renderAll();
    }catch(ex){toast('匯入失敗：'+ex.message,'❌');}
  };
  rd.readAsArrayBuffer(file);
}
function setupImport(dropId,inpId){
  const drop=document.getElementById(dropId),inp=document.getElementById(inpId);if(!drop||!inp)return;
  drop.onclick=()=>inp.click();
  inp.onchange=e=>{if(e.target.files[0])importExcel(e.target.files[0])};
  drop.ondragover=e=>{e.preventDefault();drop.classList.add('drag')};
  drop.ondragleave=()=>drop.classList.remove('drag');
  drop.ondrop=e=>{e.preventDefault();drop.classList.remove('drag');if(e.dataTransfer.files[0])importExcel(e.dataTransfer.files[0])};
}

