<body>
<!-- Modal -->
<div class="modal-bg" id="modalBg">
  <div class="modal">
    <h3 id="modalTitle">編輯</h3>
    <input type="text" id="modalInput" placeholder="名稱">
    <div class="modal-btns">
      <button class="btn btn-d btn-sm" id="modalDel" onclick="modalDelete()">刪除</button>
      <button class="btn btn-sm" onclick="closeModal()">取消</button>
      <button class="btn btn-p btn-sm" onclick="modalSave()">儲存</button>
    </div>
  </div>
</div>
<div id="toast-wrap"></div>
<div class="shell">
  <div class="page-hdr">🏗 工程缺失追蹤系統 <span>多人協作 · 即時同步</span>
    <span id="sync-indicator" style="font-size:11px;padding:3px 10px;border-radius:20px;background:rgba(255,255,255,.18);color:#fff;margin-left:8px">⏳ 連線中…</span>
    <button class="btn btn-g no-print" onclick="shareData()" style="margin-left:auto">🔗 產生分享連結</button>
  </div>
  <div class="card card-main" id="mainCard">
    <div class="tabs" id="tab-bar"></div>
    <div id="pane-main"></div>
    <div id="pane-vendor" style="display:none"></div>
    <div id="pane-warn"   style="display:none"></div>
    <div id="pane-cal"    style="display:none"></div>
    <div id="pane-zones"  style="display:none"></div>
    <div id="pane-mgr"    style="display:none"></div>
    <div id="pane-events" style="display:none"></div>
    <div id="pane-done"   style="display:none"></div>
  </div>
</div>
<script>
const SK='tracker_v5';
const DOW=['日','一','二','三','四','五','六'];
const V_COLORS=['#534AB7','#0F6E56','#993C1D','#185FA5','#3B6D11','#854F0B','#7A0055','#5F5E5A','#9C6B00','#1A6B6B'];
const TAB_BG={main:'card-main',vendor:'card-vendor',warn:'card-warn',cal:'card-cal',zones:'card-zones',mgr:'card-mgr',events:'card-event',done:'card-done'};

