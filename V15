// ── date cell named handlers (avoid nested backticks) ────────────────────
function onPlanDoneChange(id,v){
  var r=S.rows.find(x=>x.id===id);if(!r)return;
  if(!v){r.planDone=v;save();renderAll();return;}
  if(r.planIn&&v<r.planIn){toast('完成日期不可早於進場日期','⚠️');renderAll();return;}
  r.planDone=v;save();renderAll();
}
function onActualInChange(id,v){
  var r=S.rows.find(x=>x.id===id);if(!r)return;
  if(!v){r.actualIn=v;save();renderAll();return;}
  if(r.actualDone&&v>r.actualDone){toast('實際進場不可晚於實際完成','⚠️');renderAll();return;}
  r.actualIn=v;save();renderAll();
}
function onActualDoneChange(id,v){
  var r=S.rows.find(x=>x.id===id);if(!r)return;
  if(!v){r.actualDone=v;save();renderAll();return;}
  if(r.actualIn&&v<r.actualIn){toast('實際完成不可早於實際進場','⚠️');renderAll();return;}
  r.actualDone=v;if(v&&!r.actualIn)r.actualIn=v;save();renderAll();
}
function dateCell(id,planF,planV,actualF,actualV){
  const planDow=dowStr(planV),actualDow=dowStr(actualV);
  // Use named handlers to avoid nested backtick issue
  const onPlanChange=planF==='planIn'
    ?'onPlanInChange('+id+',this.value)'
    :'onPlanDoneChange('+id+',this.value)';
  const onActualChange=actualF==='actualIn'
    ?'onActualInChange('+id+',this.value)'
    :'onActualDoneChange('+id+',this.value)';
  const r=S.rows.find(x=>x.id===id);
  const planConflict=r&&planF==='planDone'&&planV&&r.planIn&&planV<r.planIn;
  const actualConflict=r&&actualF==='actualDone'&&actualV&&r.actualIn&&actualV<r.actualIn;
  const planStyle='width:110px'+(planConflict?';color:var(--red);font-weight:600;border-color:var(--red)':'');
  const actualStyle='width:110px'+(actualConflict?';color:var(--red);font-weight:600;border-color:var(--red)':'');
  return '<td style="vertical-align:top;padding:3px 4px">'
    +'<div class="date-wrap">'
    +'<span class="date-pre plan">預</span>'
    +'<input type="date" value="'+planV+'" onchange="'+onPlanChange+'" onclick="event.stopPropagation()" style="'+planStyle+'">'
    +'<span class="dow-lbl">'+planDow+'</span>'
    +'</div>'
    +'<div class="date-wrap" style="margin-top:2px">'
    +'<span class="date-pre actual">實</span>'
    +'<input type="date" value="'+actualV+'" onchange="'+onActualChange+'" onclick="event.stopPropagation()" style="'+actualStyle+'">'
    +'<span class="dow-lbl">'+actualDow+'</span>'
    +'</div>'
    +'</td>';
}

