// ── drag-sort helpers ─────────────────────────────────────────────────────
let dragSrc=null;
function dsDragStart(e,idx,listKey){
  dragSrc={idx,listKey};
  e.dataTransfer.effectAllowed='move';
  e.dataTransfer.setData('text/plain',idx);
}
function dsDragOver(e,el){e.preventDefault();el.classList.add('drag-over');}
function dsDragLeave(el){el.classList.remove('drag-over');}
function dsDrop(e,toIdx,listKey,rerender){
  e.preventDefault();
  document.querySelectorAll('.ed-item').forEach(el=>el.classList.remove('drag-over'));
  if(!dragSrc||dragSrc.listKey!==listKey||dragSrc.idx===toIdx)return;
  const arr=listKey==='vendor'?S.vendors:listKey==='zone'?S.zones:listKey==='mgr'?S.managers:null;
  if(!arr)return;
  const item=arr.splice(dragSrc.idx,1)[0];arr.splice(toIdx,0,item);
  dragSrc=null;save();rerender();
}
// tab drag-sort
let tabDragSrc=null;
function tabDragStart(e,id){tabDragSrc=id;e.dataTransfer.effectAllowed='move';}
function tabDragOver(e,id){
  e.preventDefault();
  document.querySelectorAll('.tab').forEach(t=>{
    t.classList.toggle('tab-drag-over',t.dataset.id===id&&id!==tabDragSrc);
  });
