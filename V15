const TODAY=new Date();TODAY.setHours(0,0,0,0);
const todayISO=()=>TODAY.toISOString().slice(0,10);
const pd=s=>{if(!s)return null;const d=new Date(s);d.setHours(0,0,0,0);return isNaN(d)?null:d};
const du=s=>{const d=pd(s);if(!d)return null;return Math.ceil((d-TODAY)/86400000)};
const fmtMD=s=>{const d=pd(s);if(!d)return'';return`${d.getMonth()+1}/${d.getDate()}(${DOW[d.getDay()]})`};
const esc=s=>String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
const dotC=st=>({done:'#2E6B26',ongoing:'#185FA5',overdue:'#A32D2D',pending:'#B4B2A9'})[st]||'#B4B2A9';
function getStatus(r){
  if(r.actualDone)return'done';
  const d=du(r.planDone);
  if(d!==null&&d<0)return'overdue';
  if(r.actualIn)return'ongoing';
  return'pending';
}
function dot(st){return`<span class="dot" style="background:${dotC(st)}"></span>`}
function badge(r){
  const st=getStatus(r),d=du(r.planDone);
  if(st==='done')return`<span class="badge bdone">✅完成</span>`;
  if(st==='overdue')return`<span class="badge bover">🔴逾期</span>`;
  if(d!==null&&d<=3)return`<span class="badge b3">🟠${d}天</span>`;
  if(d!==null&&d<=7)return`<span class="badge b7">🔵${d}天</span>`;
  return`<span style="color:var(--text3);font-size:10px">—</span>`;
}
function rClass(r){
  const st=getStatus(r),d=du(r.planDone);
  if(st==='done')return'r-done';if(st==='overdue')return'r-over';
  if(d!==null&&d<=3)return'r-w3';if(d!==null&&d<=7)return'r-w7';return'';
}
