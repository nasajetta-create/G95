// ── PDF 會議記錄匯入 ──────────────────────────────────────────────────────
function setupPdfImport(dropId, inpId){
  const drop=document.getElementById(dropId), inp=document.getElementById(inpId);
  if(!drop||!inp)return;
  drop.onclick=()=>inp.click();
  inp.onchange=e=>{if(e.target.files[0])importMeetingPDF(e.target.files[0]);};
  drop.ondragover=e=>{e.preventDefault();drop.classList.add('drag');};
  drop.ondragleave=()=>drop.classList.remove('drag');
  drop.ondrop=e=>{e.preventDefault();drop.classList.remove('drag');if(e.dataTransfer.files[0])importMeetingPDF(e.dataTransfer.files[0]);};
}

async function importMeetingPDF(file){
  if(!file.name.toLowerCase().endsWith('.pdf')){toast('請選擇 PDF 檔案','⚠️');return;}
  toast('正在解析 PDF 會議記錄，請稍候…','⏳');
  try{
    const base64=await new Promise((res,rej)=>{
      const r=new FileReader();
      r.onload=()=>res(r.result.split(',')[1]);
      r.onerror=()=>rej(new Error('讀取失敗'));
      r.readAsDataURL(file);
    });
    const resp=await fetch('https://pdf-proxy.nasa-jetta.workers.dev',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({pdfBase64:base64,filename:file.name})
    });
    if(!resp.ok){
      const err=await resp.json().catch(()=>({}));
      throw new Error(err.error||'Worker 錯誤 '+resp.status);
    }
    const data=await resp.json();
    if(data.error)throw new Error(data.error);
    const text=data.text||'{"items":[]}';
    let parsed;
    try{
      const clean=text.replace(/```json|```/g,'').trim();
      parsed=JSON.parse(clean);
    }catch(e){throw new Error('解析 AI 回應失敗：'+e.message);}
    const items=parsed.items||[];
    if(!items.length){toast('PDF 中未找到議題內容，請確認 PDF 格式','⚠️');return;}
    let added=0;
    items.forEach(item=>{
      if(!item.content&&!item.remark)return;
      if(item.manager&&!S.managers.includes(item.manager))S.managers.push(item.manager);
      S.alerts.push({
        id:S.nextAlertId++,
        manager:item.manager||'',
        unit:item.unit||'',
        location:item.location||'',
        content:item.content||'',
        limitDate:item.limitDate||'',
        doneDate:'',
        remark:item.remark||''
      });
      added++;
    });
    save();renderMain();
    toast('PDF 匯入完成：已新增 '+added+' 筆議題','✅');
  }catch(e){
    console.error('[PDF Import]',e);
    toast('PDF 匯入失敗：'+e.message,'❌');
  }
}


// ── 勾選完成：移至已完成看板 ─────────────────────────────────────────────
function markDone(id){
  const r=S.rows.find(x=>x.id===id);
  if(!r){renderAll();return;}
  if(!confirm('確定將「'+r.issue+'」標記為完成並移至已完成工作看板？')){renderAll();return;}
  // 設定實際完成日期（若無）
  if(!r.actualDone)r.actualDone=todayISO();
  if(!r.actualIn)r.actualIn=r.planIn||todayISO();
  // 複製到 completed
  S.completed.push({...r,compId:S.nextCompId++,completedAt:todayISO()});
  // 從 rows 移除
  S.rows=S.rows.filter(x=>x.id!==id);
  selectedIds.delete(id);
  save();renderAll();
  toast('已移至「已完成工作」看板 ✅');
}

