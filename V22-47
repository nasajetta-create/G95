// ── PANE: Calendar ────────────────────────────────────────────────────────
function renderCal(){
  const base=new Date(TODAY);
  const dow=base.getDay();base.setDate(base.getDate()+(dow===0?-6:1-dow)+calOffset*14);
  const cells=[];for(let i=0;i<14;i++){const d=new Date(base);d.setDate(base.getDate()+i);cells.push(d);}
  const lbl=`${cells[0].getFullYear()}年 ${fmtMD(cells[0].toISOString().slice(0,10))} — ${fmtMD(cells[13].toISOString().slice(0,10))}`;
  const dateMap={};
  const addEv=(ds,type,r)=>{if(!ds)return;const k=ds.slice(0,10);if(!dateMap[k])dateMap[k]=[];dateMap[k].push({type,r});};
  S.rows.forEach(r=>{addEv(r.planIn,'in',r);addEv(r.planDone,'done',r);addEv(r.actualDone,'ad',r);});
  const ovRows=S.rows.filter(r=>getStatus(r)==='overdue');
  const ovByV={};ovRows.forEach(r=>{const v=r.vendor||'（未指定）';if(!ovByV[v])ovByV[v]=[];ovByV[v].push(r);});
  let cal=`<div class="tbl-wrap">
    <div class="cal-nav">
      <button class="btn no-print" onclick="calOffset--;renderCal()">← 上兩週</button>
      <span class="cal-lbl">${lbl}</span>
      <button class="btn no-print" onclick="calOffset++;renderCal()">下兩週 →</button>
    </div>
    <div class="cal-legend">
      <span><span class="ldot" style="background:#B5D4F4"></span>預計進場</span>
      <span><span class="ldot" style="background:#C0DD97"></span>預計完成</span>
      <span><span class="ldot" style="background:#CECBF6"></span>實際完成</span>
    </div>
    <div class="cal-grid">`;
  ['一','二','三','四','五','六','日'].forEach((h,i)=>cal+=`<div class="cal-dow${i>=5?' wknd':''}">${h}</div>`);
  cells.forEach((cd,i)=>{
    const iso=cd.toISOString().slice(0,10),isToday=iso===todayISO(),isWknd=(i%7)>=5;
    const dn=isToday?`<div class="cal-dnum today-n">${cd.getDate()}</div>`:`<div class="cal-dnum">${fmtMD(iso)}</div>`;
    const evs=(dateMap[iso]||[]).sort((a,b)=>a.r.zone.localeCompare(b.r.zone)||a.r.vendor.localeCompare(b.r.vendor));
    let lastZ='',lastV='',evH='';
    evs.forEach(ev=>{
      const zc=zColor(ev.r.zone),vc=vColor(ev.r.vendor);
      if(ev.r.zone!==lastZ){evH+=`<div class="cal-ev" style="background:${zc}22;color:${zc};font-weight:600">${esc(zLabel(ev.r.zone))}</div>`;lastZ=ev.r.zone;lastV='';}
      if(ev.r.vendor!==lastV){evH+=`<div class="cal-ev" style="background:${vc}22;color:${vc}">${esc(ev.r.vendor)}</div>`;lastV=ev.r.vendor;}
      const tc={in:'ev-in',done:'ev-done',ad:'ev-ad'}[ev.type]||'';
      const icon={in:'▶',done:'✔',ad:'★'}[ev.type]||'';
      // 摘要：圖示+戶別縮寫+工項前5字
      const sumUnit=esc(ev.r.unit).slice(0,6);
      const sumIssue=esc(ev.r.issue).slice(0,5);
      evH+=`<div class="cal-ev ${tc}" title="${esc(ev.r.unit+' | '+ev.r.issue+' ['+{in:'預計進場',done:'預計完成',ad:'實際完成'}[ev.type]+']')}">${icon} ${sumUnit} ${sumIssue}</div>`;
    });
    cal+=`<div class="cal-cell${isToday?' today-c':''}${isWknd?' wknd-c':''}">${dn}${evH}</div>`;
  });
  cal+='</div></div>';
  let ovHtml='';
  if(ovRows.length){
    ovHtml=`<div class="sec" style="margin-top:12px">
      <div class="sec-hdr" style="background:#FFE8E8;color:#6B0000">
        <div class="sec-hdr-l">🔴 已逾期項目（${ovRows.length}項）— 依廠商分類</div>
        <button class="btn btn-pdf no-print" onclick="printSection('已逾期',pdfTable(S.rows.filter(r=>getStatus(r)==='overdue'),true))">🖨 PDF</button>
      </div>
      ${Object.entries(ovByV).map(([vn,vr])=>`
        <div style="margin:6px 8px;border:1px solid var(--border2);border-radius:7px;overflow:hidden">
          <div style="background:#FFF4F4;padding:5px 10px;font-size:11px;font-weight:600;border-bottom:1px solid var(--border2);display:flex;align-items:center;gap:6px">
            <span style="width:8px;height:8px;border-radius:2px;background:${vColor(vn)};display:inline-block"></span>
            ${esc(vn)} <span style="font-weight:400;color:var(--text2)">（${vr.length}項）</span>
          </div>
          <table style="width:100%;border-collapse:collapse;font-size:11px"><thead><tr style="background:#FAFAF8">
            ${['管理人','戶別','樓層','缺失','預計完成','區域'].map(h=>`<th style="padding:4px 7px;font-size:10px;font-weight:600;color:var(--text2);border-bottom:1px solid var(--border2)">${h}</th>`).join('')}
          </tr></thead>
          <tbody>${vr.map(r=>`<tr style="border-bottom:1px solid var(--border2);background:var(--red-lt)">
            <td style="padding:4px 7px;color:var(--text2)">${esc(r.manager)||'—'}</td>
            <td style="padding:4px 7px">${esc(r.unit)}</td>
            <td style="padding:4px 7px;text-align:center">${esc(r.floor)}</td>
            <td style="padding:4px 7px">${esc(r.issue)}</td>
            <td style="padding:4px 7px;text-align:center;color:var(--red);font-weight:600">${fmtMD(r.planDone)}</td>
            <td style="padding:4px 7px"><span style="font-size:10px;padding:2px 5px;border-radius:8px;background:${zColor(r.zone)}22;color:${zColor(r.zone)}">${esc(zLabel(r.zone))}</span></td>
          </tr>`).join('')}</tbody></table>
        </div>`).join('')}
    </div>`;
  }
  document.getElementById('pane-cal').innerHTML=`
    <div class="bar no-print">
      <button class="btn btn-pdf" onclick="printSection('雙週行事曆',document.querySelector('#pane-cal .tbl-wrap').outerHTML)">🖨 PDF</button>
    </div>${cal}${ovHtml}`;
}

