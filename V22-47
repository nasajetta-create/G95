function printSummaryTablePdf(){
  // Rebuild the table data independently for PDF
  if(!S.handoverUnits)S.handoverUnits={};
  const isOwnerK=k=>k&&k.startsWith('地');
  const isBizK=k=>k&&k.startsWith('業');
  const isNormalK=k=>k&&!k.startsWith('地')&&!k.startsWith('業');
  function countU(rawData,fn){let t=0,d=0;Object.values(rawData).forEach(col=>Object.values(col).forEach(k=>{if(!k||!fn(k))return;t++;if(S.handoverUnits[k]&&S.handoverUnits[k].delivered)d++;}));return{t,d,r:t-d};}
  const shopKeys=['地A1-1','A2-1','A3-1','業A5-1','地A6-1','地A7-1','地A8-1','地A9-1','地A10-1','地A11-1','地A12-1','地A15-1','地A16-1','地A17-1','地A18-1','地A19-1','地A20-1','地A21-1','地A22-1','地A23-1','地A25-1','地A26-1','地A27-1','業A28-1','地A29-1','業A30-1','業C2-1','地C1-2'];
  function countS(fn){let t=0,d=0;shopKeys.forEach(k=>{if(!fn(k))return;t++;if(S.handoverUnits[k]&&S.handoverUnits[k].delivered)d++;});return{t,d,r:t-d};}
  const rows=[['','A棟 地主','A棟 自購','A棟 業主','B棟 地主','B棟 自購','B棟 業主','店鋪 地主','店鋪 自購','店鋪 業主','全案 地主','全案 自購','全案 業主']];
  ['總戶數','交屋完成','剩餘戶數'].forEach((label,ri)=>{
    const v=(obj)=>ri===0?obj.t:ri===1?obj.d:obj.r;
    const a=[isOwnerK,isNormalK,isBizK].map(fn=>v(countU(G95_RAW_A,fn)));
    const b=[isOwnerK,isNormalK,isBizK].map(fn=>v(countU(G95_RAW_B,fn)));
    const s=[isOwnerK,isNormalK,isBizK].map(fn=>v(countS(fn)));
    const tot=[0,1,2].map(i=>a[i]+b[i]+s[i]);
    rows.push([label,...a,...b,...s,...tot]);
  });
  const thead=`<tr>${rows[0].map((h,i)=>
    `<th style="padding:5px 6px;text-align:center;border:1px solid #ccc;font-size:10px;font-weight:600;background:#ECEAE6;${i>=10?'color:#3C3489':''}">${h}</th>`).join('')}</tr>`;
  const tbodyRows=rows.slice(1).map((row,ri)=>{
    const color=ri===1?'color:#2E6B26':ri===2?'color:#A32D2D':'';
    return`<tr style="${color}">${row.map((v,ci)=>`<td style="padding:5px 6px;text-align:${ci===0?'left':'center'};border:1px solid #ccc;font-size:11px;${ci>=10?'font-weight:600;color:inherit':''}">${v}</td>`).join('')}</tr>`;
  }).join('');
  printSection('交屋狀態統計表',`<table style="width:100%;border-collapse:collapse"><thead>${thead}</thead><tbody>${tbodyRows}</tbody></table>`);
}


