      <div class="vc-row"><span style="color:var(--text2)">負責項目</span><b>${total}</b></div>
      <div class="vc-row"><span style="color:var(--text2)">已完成</span><b style="color:var(--green)">${done}</b></div>
      <div class="vc-row"><span style="color:var(--text2)">逾期</span><b style="color:var(--red)">${over}</b></div>
      <div class="prog-wrap"><div class="prog-bar" style="width:${pct}%;background:${vColor(m)}"></div></div>
      <div class="prog-lbl">${pct}%</div>
    </div>`;
  }).join('');
  let detail='';
  if(selMgr){
    const mZoneFilter=window._mgrZone||'all';
    const mRowsAll=S.rows.filter(r=>{
      if(r.manager!==selMgr)return false;
      if(mZoneFilter!=='all'&&r.zone!==mZoneFilter)return false;
