// ── 重點提示事項：匯入檔案分流（PDF / Excel） ──────────────────────────
function handleAlertImport(file){
  if(!file)return;
  const ext=file.name.split('.').pop().toLowerCase();
  if(ext==='pdf'){
    importMeetingPDF(file);
  } else if(['xlsx','xls','csv'].includes(ext)){
    importAlertExcel(file);
  } else {
    toast('不支援的檔案格式，請選擇 PDF 或 Excel','⚠️');
  }
}
function importAlertExcel(file){
  const rd=new FileReader();
  rd.onload=e=>{
    try{
      const wb=XLSX.read(e.target.result,{type:'array',cellDates:false,raw:true});
      const wsName=wb.SheetNames.find(n=>n.includes('提示')||n.includes('議題')||n.includes('會議'))||wb.SheetNames[0];
      const raw=XLSX.utils.sheet_to_json(wb.Sheets[wsName],{defval:'',raw:true});
      if(!raw.length){toast('Excel 無有效資料','⚠️');return;}
      const AMAP={
        '管理人':'manager','負責人':'manager',
        '對應單位':'unit','單位':'unit',
        '區域位置':'location','位置':'location','區域':'location',
        '內容說明':'content','缺失內容':'content','說明':'content','議題':'content',
        '限辦日期':'limitDate','期限':'limitDate','完成期限':'limitDate',
        '實際完成日期':'doneDate','完成日期':'doneDate',
        '備註事項':'remark','備註':'remark'
      };
      let added=0,skipped=0;
      raw.forEach(row=>{
        const mapped={};
        Object.entries(row).forEach(([k,v])=>{
          const fk=AMAP[k.trim()];if(!fk)return;
          if(['limitDate','doneDate'].includes(fk))mapped[fk]=excelToISO(v);
          else mapped[fk]=String(v||'').trim();
        });
        if(!mapped.content&&!mapped.unit){skipped++;return;}
        if(mapped.manager&&!S.managers.includes(mapped.manager))S.managers.push(mapped.manager);
        S.alerts.push({
          id:S.nextAlertId++,
          manager:mapped.manager||'',
          unit:mapped.unit||'',
          location:mapped.location||'',
          content:mapped.content||'',
          limitDate:mapped.limitDate||'',
          doneDate:mapped.doneDate||'',
          remark:mapped.remark||''
        });
        added++;
      });
      save();renderMain();
      toast(`Excel 匯入完成：新增 ${added} 筆，略過 ${skipped} 筆`,'📊');
      logChange('📂 提示事項匯入',`檔案：${file.name}，新增 ${added} 筆`);
    }catch(ex){toast('匯入失敗：'+ex.message,'❌');}
  };
  rd.readAsArrayBuffer(file);
}


function setupPdfImport(dropId, inpId){
  const drop=document.getElementById(dropId), inp=document.getElementById(inpId);
  if(!drop||!inp)return;
  drop.onclick=()=>inp.click();
  inp.onchange=e=>{if(e.target.files[0])importMeetingPDF(e.target.files[0]);};
  drop.ondragover=e=>{e.preventDefault();drop.classList.add('drag');};
  drop.ondragleave=()=>drop.classList.remove('drag');
  drop.ondrop=e=>{e.preventDefault();drop.classList.remove('drag');if(e.dataTransfer.files[0])importMeetingPDF(e.dataTransfer.files[0]);};
}

async function importMeetingPDF(file){
  if(!file.name.toLowerCase().endsWith('.pdf')){toast('請選擇 PDF 檔案','⚠️');return;}
  toast('正在解析 PDF 會議記錄，請稍候…','⏳');
  try{
    const base64=await new Promise((res,rej)=>{
      const r=new FileReader();
      r.onload=()=>res(r.result.split(',')[1]);
      r.onerror=()=>rej(new Error('讀取失敗'));
      r.readAsDataURL(file);
    });
    const resp=await fetch('https://pdf-proxy.nasa-jetta.workers.dev',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({pdfBase64:base64,filename:file.name})
    });
    if(!resp.ok){
      const err=await resp.json().catch(()=>({}));
      throw new Error(err.error||'Worker 錯誤 '+resp.status);
    }
    const data=await resp.json();
    if(data.error)throw new Error(data.error);
    const text=data.text||'{"items":[]}';
    let parsed;
    try{
      const clean=text.replace(/```json|```/g,'').trim();
      parsed=JSON.parse(clean);
    }catch(e){throw new Error('解析 AI 回應失敗：'+e.message);}
    const items=parsed.items||[];
    if(!items.length){toast('PDF 中未找到議題內容，請確認 PDF 格式','⚠️');return;}
    let added=0;
    items.forEach(item=>{
      if(!item.content&&!item.remark)return;
      if(item.manager&&!S.managers.includes(item.manager))S.managers.push(item.manager);
      S.alerts.push({
        id:S.nextAlertId++,
        manager:item.manager||'',
        unit:item.unit||'',
        location:item.location||'',
        content:item.content||'',
        limitDate:item.limitDate||'',
        doneDate:'',
        remark:item.remark||''
      });
      added++;
    });
    save();renderMain();
    toast('PDF 匯入完成：已新增 '+added+' 筆議題','✅');
    logChange('📄 PDF 匯入',`檔案：${file.name}，新增 ${added} 筆重點提示`);
  }catch(e){
    console.error('[PDF Import]',e);
    toast('PDF 匯入失敗：'+e.message,'❌');
  }
}


// ── 勾選完成：移至已完成看板 ─────────────────────────────────────────────
function bulkMarkDone(){
  const doneIds=[...selectedIds].filter(id=>{
    const r=S.rows.find(x=>x.id===id);
    return r&&getStatus(r)==='done';
  });
  if(!doneIds.length){toast('選取項目中沒有狀態為「已完成」的項目','⚠️');return;}
  const notDone=[...selectedIds].filter(id=>{
    const r=S.rows.find(x=>x.id===id);
    return r&&getStatus(r)!=='done';
  });
  let msg='確定將 '+doneIds.length+' 筆已完成項目移至已完成工作看板？';
  if(notDone.length)msg+='\n（另有 '+notDone.length+' 筆非完成狀態的項目將被略過）';
  if(!confirm(msg))return;
  doneIds.forEach(id=>{
    const r=S.rows.find(x=>x.id===id);
    if(!r)return;
    if(!r.actualDone)r.actualDone=todayISO();
    if(!r.actualIn)r.actualIn=r.planIn||todayISO();
    S.completed.push({...r,compId:S.nextCompId++,completedAt:todayISO()});
    S.rows=S.rows.filter(x=>x.id!==id);
    selectedIds.delete(id);
  });
  save();renderAll();
  toast('已移動 '+doneIds.length+' 筆至「已完成工作」看板 ✅');
}
function markDone(id){
  const r=S.rows.find(x=>x.id===id);
  if(!r){renderAll();return;}
  if(!confirm('確定將「'+r.issue+'」標記為完成並移至已完成工作看板？')){renderAll();return;}
  // 設定實際完成日期（若無）
  if(!r.actualDone)r.actualDone=todayISO();
  if(!r.actualIn)r.actualIn=r.planIn||todayISO();
  // 複製到 completed
  S.completed.push({...r,compId:S.nextCompId++,completedAt:todayISO()});
  // 從 rows 移除
  S.rows=S.rows.filter(x=>x.id!==id);
  selectedIds.delete(id);
  save();renderAll();
  toast('已移至「已完成工作」看板 ✅');
}

// ── PANE: Main ────────────────────────────────────────────────────────────
function renderMain(){
  const fUnit=(document.getElementById('fUnit')||{}).value||'';
  const fFloor=(document.getElementById('fFloor')||{}).value||'';
  const fVendor=(document.getElementById('fVendor')||{}).value||'';
  const fZone=(document.getElementById('fZone')||{}).value||'';
  const fStatus=(document.getElementById('fStatus')||{}).value||'';
  const fMgr=(document.getElementById('fMgr')||{}).value||'';
  let data=[...S.rows];
  if(fUnit)data=data.filter(r=>r.unit===fUnit);
  if(fFloor)data=data.filter(r=>r.floor===fFloor);
  if(fVendor)data=data.filter(r=>r.vendor===fVendor);
  if(fZone)data=data.filter(r=>r.zone===fZone);
  if(fStatus)data=data.filter(r=>getStatus(r)===fStatus);
  if(fMgr)data=data.filter(r=>r.manager===fMgr);

  // ── 自動排序：逾期頂置 > 非完成 > 已完成置底 ──────────────────────
  // 群組：0=逾期  1=進行中/未開始  2=已完成(done但仍在rows)
  const grp=r=>{
    const st=getStatus(r);
    if(st==='overdue')return 0;
    if(st==='done')return 2;
    return 1;
  };
  // 逾期：廠商(S.vendors順序) > 延遲天數多→少(du越小越逾期)
  // 進行中/未開始：廠商 > planDone由近到遠
  // 已完成：廠商 > actualDone由近到遠
  const vIdx=v=>{
    const i=S.vendors.indexOf(v);
    return i>=0?i:999;
  };
  data.sort((a,b)=>{
    const ga=grp(a),gb=grp(b);
    if(ga!==gb)return ga-gb;
    const va=vIdx(a.vendor||''),vb=vIdx(b.vendor||'');
    if(va!==vb)return va-vb;
    if(ga===0){
      // 逾期：延遲天數多到少（du越負越嚴重）
      const da=du(a.planDone)??0,db=du(b.planDone)??0;
      return da-db; // 負更多的（更逾期）排前面
    }
    if(ga===2){
      // 已完成：完成日期近到遠
      return (a.actualDone||'9999').localeCompare(b.actualDone||'9999');
    }
    // 進行中/未開始：planDone 近到遠
    return (a.planDone||'9999').localeCompare(b.planDone||'9999');
  });
  // ────────────────────────────────────────────────────────────────────

  const total=S.rows.length,done=S.rows.filter(r=>r.actualDone).length;
  const over=S.rows.filter(r=>getStatus(r)==='overdue').length;
  const w3=S.rows.filter(r=>{const d=du(r.planDone);return d!==null&&d>=0&&d<=3&&!r.actualDone}).length;
  const units=uniqueUnits();
  const floors=[...new Set(S.rows.map(r=>r.floor).filter(Boolean))].sort((a,b)=>a.localeCompare(b,'zh-TW',{numeric:true}));
  const uOp=units.map(u=>`<option value="${esc(u)}"${u===fUnit?' selected':''}>${esc(u)}</option>`).join('');
  const flOp=floors.map(f=>`<option value="${esc(f)}"${f===fFloor?' selected':''}>${esc(f)}</option>`).join('');
  const vOp=S.vendors.map(v=>`<option value="${esc(v)}"${v===fVendor?' selected':''}>${esc(v)}</option>`).join('');
  const zOp=S.zones.map(z=>`<option value="${z.id}"${z.id===fZone?' selected':''}>${esc(z.label)}</option>`).join('');
  const mOp=['', ...S.managers].map(m=>`<option value="${esc(m)}"${m===fMgr?' selected':''}>${m?esc(m):'— 管理人 —'}</option>`).join('');
  const totalFiltered=data.length;
  const totalPages=Math.max(1,Math.ceil(totalFiltered/PAGE_SIZE));
  if(mainPage>=totalPages)mainPage=0;
  const pageData=data.slice(mainPage*PAGE_SIZE,(mainPage+1)*PAGE_SIZE);
  const visIds=pageData.map(r=>r.id);
  const allFilteredIds=data.map(r=>r.id);  // 篩選後所有頁的 ID
  document.getElementById('pane-main').innerHTML=`
    ${alertsHTML()}
    <div class="bar">
      <select id="fUnit" onchange="mainPage=0;renderMain()"><option value="">全部戶別</option>${uOp}</select>
      <select id="fFloor" onchange="mainPage=0;renderMain()"><option value="">全部樓層</option>${flOp}</select>
      <select id="fVendor" onchange="mainPage=0;renderMain()"><option value="">全部廠商</option>${vOp}</select>
      <select id="fZone" onchange="mainPage=0;renderMain()"><option value="">全部區域</option>${zOp}</select>
      <select id="fMgr" onchange="mainPage=0;renderMain()"><option value="">全部管理人</option>${mOp}</select>
      <select id="fStatus" onchange="mainPage=0;renderMain()">
        <option value="">全部狀態</option>
        <option value="pending"${fStatus==='pending'?' selected':''}>未開始</option>
        <option value="ongoing"${fStatus==='ongoing'?' selected':''}>進行中</option>
        <option value="done"${fStatus==='done'?' selected':''}>已完成</option>
        <option value="overdue"${fStatus==='overdue'?' selected':''}>逾期</option>
      </select>
      <button class="btn btn-p no-print" onclick="showInlineAdd()">＋ 新增</button>
      <button class="btn no-print" onclick="exportCSV()">↓ CSV</button>
      <button class="btn btn-pdf no-print" id="mainPdf">🖨 PDF</button>
    </div>
    <div class="import-drop no-print" id="iDrop">📂 拖曳 Excel 檔案到此匯入，或點此選擇<br><span style="font-size:10px;color:var(--text3)">支援欄位：管理人 區域 戶別 樓層 廠商 缺失內容 備註 預計進場 預計完成 實際進場 實際完成（廠商/管理人若不存在將自動新增）</span></div>
    <input id="iInp" type="file" accept=".xlsx,.xls,.csv" style="display:none">
    <div id="inline-add-area"></div>
    <div class="stats">
      <div class="stat"><div class="stat-l">總項目</div><div class="stat-v">${total}</div></div>
      <div class="stat"><div class="stat-l">已完成</div><div class="stat-v" style="color:var(--green)">${done}</div></div>
      <div class="stat"><div class="stat-l">逾期</div><div class="stat-v" style="color:var(--red)">${over}</div></div>
      <div class="stat"><div class="stat-l">3天警示</div><div class="stat-v" style="color:var(--amber)">${w3}</div></div>
    </div>
    ${bulkBarHTML(visIds,allFilteredIds)}
    ${pgBarHTML(totalFiltered,mainPage,'setMainPage')}${tblHTML(pageData,true,allFilteredIds)}${pgBarHTML(totalFiltered,mainPage,'setMainPage')}
  `;
  setupImport('iDrop','iInp');wireBulk();
  document.getElementById('mainPdf').onclick=()=>printSection('追蹤總表',pdfTable(data,true));
}


