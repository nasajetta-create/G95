// ── persist ───────────────────────────────────────────────────────────────
let _saveTimer=null;
let _fbListening=false;

function setSyncStatus(status){
  const el=document.getElementById('sync-indicator');
  if(!el)return;
  const map={
    connecting:['⏳ 連線中…','rgba(255,255,255,.18)'],
    online:    ['🟢 已同步',  'rgba(46,107,38,.55)'],
    saving:    ['🔄 儲存中…','rgba(60,52,137,.45)'],
    offline:   ['🟡 離線模式','rgba(122,66,0,.45)'],
    error:     ['🔴 同步失敗','rgba(163,45,45,.45)'],
  };
  const [txt,bg]=map[status]||map.offline;
  el.textContent=txt;el.style.background=bg;
}

// ── 更新紀錄 ──────────────────────────────────────────────────────────────
function logChange(type, detail){
  if(!S.changelog)S.changelog=[];
  S.changelog.unshift({
    ts: new Date().toISOString(),
    type: type||'更新',
    detail: detail||'',
    rowCount: S.rows.length
  });
  // 最多保留 500 筆
  if(S.changelog.length>500)S.changelog=S.changelog.slice(0,500);
}

function save(){
  try{localStorage.setItem(SK,JSON.stringify(S));}catch(e){}
  if(window._fbSave){
    setSyncStatus('saving');
    clearTimeout(_saveTimer);
    // 防抖 1500ms：使用者停止操作後才上傳，避免每個字都觸發 Firestore
    _saveTimer=setTimeout(async()=>{
      await window._fbSave(S);
      _saveTimer=null;
      setSyncStatus('online');
    },1500);
  }
}

function applyRemote(d){
  // 若使用者正在操作（saveTimer 或 renderTimer 還在跑），略過遠端更新
  if(_saveTimer||_renderTimer)return;
  S=migrateState(d);
  try{localStorage.setItem(SK,JSON.stringify(S));}catch(e){}
  renderAll();
}

function startFirebaseListen(){
  if(_fbListening||!window._fbListen)return;
  _fbListening=true;
  window._fbListen(remote=>{
    // 忽略自己剛寫的（saveTimer 還在跑時）
    if(_saveTimer)return;
    applyRemote(remote);
    setSyncStatus('online');
  });
  setSyncStatus('online');
}

async function load(){
  // 1. 先試分享連結
  try{
    const h=location.hash.slice(1);
    if(h.startsWith('data=')){
      const d=JSON.parse(decodeURIComponent(atob(h.slice(5))));
      if(d.rows){S=migrateState(d);history.replaceState(null,'',location.pathname);toast('已從分享連結載入資料 🎉','✅');}
    }
  }catch(e){}

  // 2. 若 Firebase 已就緒，從雲端載入
  if(window._fbLoad){
    setSyncStatus('connecting');
    try{
      const remote=await window._fbLoad();
      if(remote&&remote.rows){
        S=migrateState(remote);
        try{localStorage.setItem(SK,JSON.stringify(S));}catch(e){}
        setSyncStatus('online');
        startFirebaseListen();
        return;
      }
    }catch(e){setSyncStatus('error');}
  }

  // 3. 備援：localStorage
  try{const s=localStorage.getItem(SK);if(s){const d=JSON.parse(s);if(d.rows)S=migrateState(d);}}catch(e){}
  setSyncStatus(window._fbReady?'online':'offline');
  if(window._fbReady)startFirebaseListen();
}
function migrateState(d){
  if(!d.zones)d.zones=[{id:'indoor',label:'室內缺失',color:'#534AB7'},{id:'pub_ab',label:'公設 梯廳/樓梯間',color:'#0F6E56'},{id:'pub_cd',label:'公設 RF/2F/1F/店鋪',color:'#993C1D'},{id:'basement',label:'地下室',color:'#185FA5'}];
  if(!d.managers)d.managers=[];
  if(!d.tabOrder)d.tabOrder=['events','main','zones','vendor','warn','cal','mgr','done','handover','hstats','hcal','pubarea','clients','changelog'];
  else if(!d.tabOrder.includes('events'))d.tabOrder.push('events');
  if(!d.alerts)d.alerts=[];
  if(!d.completed)d.completed=[];
  if(!d.nextCompId)d.nextCompId=(d.completed.length?Math.max(...d.completed.map(c=>c.id))+1:1);
  if(!d.managerDetails)d.managerDetails={};
  if(!d.tabOrder.includes('done'))d.tabOrder.push('done');
  if(!d.tabOrder.includes('changelog'))d.tabOrder.push('changelog');
  if(!d.tabOrder.includes('handover'))d.tabOrder.push('handover');
  if(!d.tabOrder.includes('hstats'))d.tabOrder.push('hstats');
  if(!d.tabOrder.includes('clients'))d.tabOrder.push('clients');
  if(!d.tabOrder.includes('hcal'))d.tabOrder.push('hcal');
  if(!d.tabOrder.includes('pubarea'))d.tabOrder.push('pubarea');
  d.alerts.forEach(a=>{if(!('remark' in a))a.remark='';});
  if(!d.events)d.events=[];
  if(!d.nextAlertId)d.nextAlertId=(d.alerts.length?Math.max(...d.alerts.map(a=>a.id))+1:1);
  if(!d.nextEventId)d.nextEventId=(d.events.length?Math.max(...d.events.map(e=>e.id))+1:1);
  if(!d.changelog)d.changelog=[];
  if(!d.handoverUnits)d.handoverUnits={};
  if(!d.clientData)d.clientData={};
  if(!d.publicAreaList)d.publicAreaList={A:[
    {id:'PA-R3',label:'A棟 R3F 頂樓',floor:'R3F',zone:'A'},
    {id:'PA-R2',label:'A棟 R2F 頂樓',floor:'R2F',zone:'A'},
    {id:'PA-R1',label:'A棟 R1F 頂樓',floor:'R1F',zone:'A'},
  ],B:[
    {id:'PB-R3',label:'B棟 R3F 頂樓',floor:'R3F',zone:'B'},
