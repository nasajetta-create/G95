<body>
<!-- Modal -->
<div class="modal-bg" id="modalBg">
  <div class="modal">
    <h3 id="modalTitle">編輯</h3>
    <input type="text" id="modalInput" placeholder="名稱">
    <div class="modal-btns">
      <button class="btn btn-d btn-sm" id="modalDel" onclick="modalDelete()">刪除</button>
      <button class="btn btn-sm" onclick="closeModal()">取消</button>
      <button class="btn btn-p btn-sm" onclick="modalSave()">儲存</button>
    </div>
  </div>
</div>
<div id="toast-wrap"></div>
<div class="shell">
  <div class="page-hdr">🏗 工程缺失追蹤系統 <span>多人協作 · 即時同步</span>
    <span id="sync-indicator" style="font-size:11px;padding:3px 10px;border-radius:20px;background:rgba(255,255,255,.18);color:#fff;margin-left:8px">⏳ 連線中…</span>
