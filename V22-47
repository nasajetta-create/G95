function renderDone(){
  const total=S.completed.length;

  // ── 廠商卡片：依 S.vendors 順序，顯示各廠商完成數量與各分區分布 ──
  const vmap={};
  S.completed.forEach(r=>{
    const v=r.vendor||'（未指定）';
    if(!vmap[v])vmap[v]={total:0,zones:{}};
    vmap[v].total++;
    const zl=zLabel(r.zone);
    vmap[v].zones[zl]=(vmap[v].zones[zl]||0)+1;
  });
  const orderedV=[...S.vendors.filter(v=>vmap[v]),...Object.keys(vmap).filter(v=>!S.vendors.includes(v))];
  const vcards=orderedV.map(name=>{
    const d=vmap[name];
    const col=vColor(name);
    const sel=selDoneVendor===name;
    // 各分區小標籤
    const zoneTags=Object.entries(d.zones).map(([zl,cnt])=>{
      const zc=S.zones.find(z=>z.label===zl);
      const c=zc?zc.color:'#999';
      return '<span style="font-size:9px;padding:1px 5px;border-radius:8px;background:'+c+'22;color:'+c+';margin:1px 2px 1px 0;display:inline-block">'+esc(zl)+' '+cnt+'</span>';
    }).join('');
    return '<div class="vc'+(sel?' sel':'')+'" onclick="toggleDoneVendor(\''+esc(name)+'\')" style="cursor:pointer">'
      +'<div class="vc-name"><span style="width:9px;height:9px;border-radius:2px;background:'+col+';display:inline-block;flex-shrink:0"></span>'+esc(name)+'</div>'
      +'<div class="vc-row"><span style="color:var(--text2)">已完成</span><b style="color:var(--green)">'+d.total+'</b></div>'
      +'<div style="margin-top:5px;line-height:1.6">'+zoneTags+'</div>'
      +'<div class="prog-wrap" style="margin-top:4px"><div class="prog-bar" style="width:'+Math.round(d.total/total*100)+'%;background:'+col+'"></div></div>'
      +'<div class="prog-lbl">'+Math.round(d.total/total*100)+'%</div>'
      +'</div>';
  }).join('');

  // ── 點選廠商後顯示各分區明細 ──
  let detail='';
  if(selDoneVendor){
    const vItems=S.completed.filter(r=>(r.vendor||'（未指定）')===selDoneVendor)
      .sort((a,b)=>{
        // 先依分區順序
        const zi=S.zones.findIndex(z=>z.id===a.zone),zj=S.zones.findIndex(z=>z.id===b.zone);
        if(zi!==zj)return zi-zj;
        // 再依實際完成日期由新到舊
        return (b.actualDone||'').localeCompare(a.actualDone||'');
      });

    // 按分區分組
    const zGroups={};
    vItems.forEach(r=>{
      const zl=zLabel(r.zone);
      if(!zGroups[zl])zGroups[zl]=[];
      zGroups[zl].push(r);
    });

    const thead='<thead><tr>'
      +'<th>#</th><th>管理人</th><th>區域</th><th>戶別</th><th>樓層</th>'
      +'<th>缺失內容</th><th>備註</th>'
      +'<th>進場日期<br><span style="font-weight:400;font-size:9px;color:var(--text3)">預/實</span></th>'
      +'<th>完成日期<br><span style="font-weight:400;font-size:9px;color:var(--text3)">預/實</span></th>'
      +'<th>完成於</th><th class="no-print">操作</th>'
      +'</tr></thead>';

    const zSections=Object.entries(zGroups).map(([zl,items])=>{
      const zc=S.zones.find(z=>z.label===zl);
      const c=zc?zc.color:'#999';
      return '<div style="margin-bottom:10px">'
        +'<div style="display:flex;align-items:center;gap:6px;padding:6px 10px;background:'+c+'18;border-left:3px solid '+c+';border-radius:0 6px 6px 0;margin-bottom:4px">'
        +'<span style="width:9px;height:9px;border-radius:2px;background:'+c+';display:inline-block"></span>'
        +'<span style="font-size:12px;font-weight:600;color:'+c+'">'+esc(zl)+'</span>'
        +'<span style="font-size:11px;color:var(--text2)">（'+items.length+' 項）</span>'
        +'</div>'
        +'<div style="overflow-x:auto"><table class="tbl" style="font-size:12px">'+thead
        +'<tbody>'+items.map(doneRowHTML).join('')+'</tbody></table></div>'
        +'</div>';
    }).join('');

    detail='<div class="sec" style="margin-top:12px">'
      +'<div class="sec-hdr" style="background:#EAF6E7;color:var(--green)">'
      +'<div class="sec-hdr-l">✅ '+esc(selDoneVendor)+' — '+vItems.length+' 筆完成項目</div>'
      +'<button class="btn btn-pdf no-print" onclick="printSection(\'已完成：'+esc(selDoneVendor)+'\',pdfTable(S.completed.filter(r=>(r.vendor||\'（未指定）\')===selDoneVendor),true))">🖨 PDF</button>'
      +'</div>'
      +zSections
      +'</div>';
  }

  document.getElementById('pane-done').innerHTML=
    '<div style="display:flex;gap:12px;align-items:flex-start;flex-wrap:wrap">'
    +'<div style="flex:1;min-width:280px">'
    +'<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">'
    +'<div>'
    +'<span style="font-size:13px;font-weight:700">✅ 已完成工作</span>'
    +'<span style="font-size:12px;color:var(--text2);margin-left:8px">共 '+total+' 筆 — 點選廠商卡片展開分區明細</span>'
    +'</div>'
    +'<div style="display:flex;gap:6px">'
    +'<button class="btn btn-pdf no-print" onclick="printDoneTable()">🖨 PDF</button>'
    +'<button class="btn no-print" onclick="selDoneVendor=null;renderDone()" style="font-size:11px;padding:4px 9px">🔄 刷新</button>'
    +'</div>'
    +'</div>'
    +(total?'<div class="vcards">'+vcards+'</div>':'<div class="empty">尚無已完成項目</div>')
    +detail
    +'</div>'
    +'</div>';
}

