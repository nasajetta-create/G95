    const parkTag=allPark2.length?allPark2.map(p=>`<div style="font-size:8px;color:#0C447C;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">🚗${esc(p)}</div>`).join(''):'';
