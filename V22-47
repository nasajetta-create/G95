// ── 客戶清單 Excel 匯入 ──────────────────────────────────────────────────
function importClientExcel(file){
  if(!file)return;
  const rd=new FileReader();
  rd.onload=e=>{
    try{
      const wb=XLSX.read(e.target.result,{type:'array',cellDates:false,raw:true});
      // 自動選最相關的分頁
      const wsName=wb.SheetNames.find(n=>n.includes('客戶')||n.includes('名單')||n.includes('住戶'))||wb.SheetNames[0];
      const raw=XLSX.utils.sheet_to_json(wb.Sheets[wsName],{defval:'',raw:true});
      if(!raw.length){toast('Excel 無有效資料','⚠️');return;}
      if(!S.clientData)S.clientData={};
      const CMAP={
        '戶別':'unit','戶號':'unit','房號':'unit',
        '姓名':'name','客戶姓名':'name','住戶姓名':'name','屋主':'name',
        '電話':'tel','聯絡電話':'tel','手機':'tel','電話號碼':'tel',
        '類型':'type','戶別類型':'type','身份':'type',
        '車位':'parking','車位編號':'parking','停車位':'parking',
        '備註':'note','注意事項':'note','說明':'note',
      };
      let added=0,updated=0;
      raw.forEach(row=>{
        const m={};
        Object.entries(row).forEach(([k,v])=>{
          const fk=CMAP[k.trim()];if(!fk)return;
          m[fk]=String(v||'').trim();
        });
        if(!m.unit)return;
        // 嘗試匹配 unitKey — 先直接比對，再試 G95 格式
        const key=m.unit;
        const existed=!!S.clientData[key];
        if(!S.clientData[key])S.clientData[key]={name:'',tel:'',type:'自購戶',parkings:[],note:''};
        if(m.name)S.clientData[key].name=m.name;
        if(m.tel)S.clientData[key].tel=m.tel;
        if(m.type)S.clientData[key].type=m.type;
        if(m.note)S.clientData[key].note=m.note;
        if(m.parking){
          const parks=m.parking.split(/[,，、\s]+/).map(p=>p.trim()).filter(Boolean);
          if(!S.clientData[key].parkings)S.clientData[key].parkings=[];
          parks.forEach(p=>{if(!S.clientData[key].parkings.includes(p))S.clientData[key].parkings.push(p);});
        }
        existed?updated++:added++;
      });
      logChange('📂 客戶清單匯入',`檔案：${file.name}，新增 ${added} 筆，更新 ${updated} 筆`);
      save();renderClients();
      toast(`客戶清單匯入完成：新增 ${added} 筆，更新 ${updated} 筆`,'✅');
    }catch(ex){toast('匯入失敗：'+ex.message,'❌');}
  };
  rd.readAsArrayBuffer(file);
}
function downloadClientTemplate(){
  // 先嘗試 XLSX，失敗則 fallback 到 CSV
  try{
    if(typeof XLSX==='undefined'||!XLSX.utils)throw new Error('XLSX 未載入');
    const ws=XLSX.utils.aoa_to_sheet([
      ['戶別','姓名','電話','類型','車位','備註'],
      ['地A1-27','張○○','0912-000-001','地主戶','B2-333、B2-334','備注1'],
      ['A3-18','李○○','0912-000-002','自購戶','',''],
      ['業A5-1','王○○','0912-000-003','業主戶','B1-100','店鋪業主'],
    ]);
    ws['!cols']=[{wch:14},{wch:10},{wch:16},{wch:10},{wch:24},{wch:20}];
    const wb=XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb,'客戶清單',ws);
    const wbout=XLSX.write(wb,{bookType:'xlsx',type:'array'});
    const blob=new Blob([wbout],{type:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'});
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a');a.href=url;a.download='客戶清單匯入範本.xlsx';
    document.body.appendChild(a);a.click();
    setTimeout(()=>{document.body.removeChild(a);URL.revokeObjectURL(url);},300);
    toast('範本已下載（xlsx）','⬇');
  }catch(ex){
    // Fallback：改用 CSV 下載
    try{
      const rows=[
        '戶別,姓名,電話,類型,車位,備註',
        '地A1-27,張○○,0912-000-001,地主戶,B2-333,備注1',
        'A3-18,李○○,0912-000-002,自購戶,,',
        '業A5-1,王○○,0912-000-003,業主戶,B1-100,店鋪業主',
      ].join('\n');
      const bom='\uFEFF'; // UTF-8 BOM 讓 Excel 正確顯示中文
      const blob=new Blob([bom+rows],{type:'text/csv;charset=utf-8'});
      const url=URL.createObjectURL(blob);
      const a=document.createElement('a');a.href=url;a.download='客戶清單匯入範本.csv';
      document.body.appendChild(a);a.click();
      setTimeout(()=>{document.body.removeChild(a);URL.revokeObjectURL(url);},300);
      toast('範本已下載（csv）','⬇');
    }catch(ex2){toast('下載失敗，請檢查瀏覽器設定','❌');}
  }
}

function printClients(){
  const keys=[];
  Object.values(G95_RAW_A).forEach(colObj=>Object.values(colObj).forEach(k=>{if(k)keys.push(k);}));
  Object.values(G95_RAW_B).forEach(colObj=>Object.values(colObj).forEach(k=>{if(k)keys.push(k);}));
  const rows=[...new Set(keys)].sort().map(key=>{
    const cl=S.clientData[key]||{};
    const staticPark=G95_PARKING[key]||[];
    const allPark=[...new Set([...staticPark,...(cl.parkings||[])])];
    return`<tr><td>${esc(key)}</td><td>${esc(cl.name||'')}</td><td>${esc(cl.tel||'')}</td><td>${esc(cl.type||'')}</td><td>${allPark.join('、')}</td><td style="max-width:200px">${esc(cl.note||'')}</td></tr>`;
