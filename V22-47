    ['地A1-1','A2-1','A3-1','業A5-1','地A6-1','地A7-1','地A8-1','地A9-1','地A10-1','地A11-1','地A12-1','地A15-1','地A16-1','地A17-1','地A18-1','地A19-1','地A20-1','地A21-1','地A22-1','地A23-1','地A25-1','地A26-1','地A27-1','業A28-1','地A29-1','業A30-1','業C2-1','地C1-2'].forEach(k=>keys.push(k));
  }
  if(!keys.length){toast('沒有符合條件的戶別','⚠️');return;}
