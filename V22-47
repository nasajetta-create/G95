      <div style="width:100%;height:3px;background:rgba(0,0,0,.1);border-radius:1px;margin-top:auto"><div style="height:3px;width:${pct}%;background:${grade.color};border-radius:1px"></div></div>
    </div>`;
  }

  // 分隔線邏輯：在 5/10/15/20/25/31 的「下方」加粗線，即這些樓層的 margin-bottom
  // MILESTONE_BELOW = 樓層下方要加分隔線的樓層（例如 5F 下方→5和4之間加線）
  const MILESTONE_BELOW=new Set([5,10,15,20,25,31]);

  function buildCol2(rawData,cols,title,blockId){
    const colHdrs=`<div></div>`+cols.map(c=>`<div style="font-size:13px;text-align:center;color:var(--text2);font-weight:600;padding:3px 0">${c}</div>`).join('');
