        ${hu.delivered?`<span style="font-size:10px;padding:1px 6px;border-radius:20px;background:#EAF3DE;color:#3B6D11">✓ 已交屋</span>`:''}
        ${warnTag}
        <div style="width:60px;height:5px;background:#E8E6E2;border-radius:3px;overflow:hidden"><div style="height:5px;width:${pct}%;background:${grade.color};border-radius:3px"></div></div>
        <span style="font-size:10px;color:${grade.color};font-weight:600">${pct}%</span>
      </div>
