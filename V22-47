function hoUnitPct(unit){
  const rows=S.rows.filter(r=>r.unit===unit);
  if(!rows.length)return null;
  return Math.round(rows.filter(r=>r.actualDone).length/rows.length*100);
}
function hoGrade(pct){
  if(pct===null)return{label:'無資料',color:'#B4B2A9',bg:'#F1EFE8'};
  if(pct===100)return{label:'✅ 可交屋',color:'#3B6D11',bg:'#EAF3DE'};
  if(pct>=90) return{label:'🔵 接近完成',color:'#185FA5',bg:'#E6F1FB'};
  if(pct>=80) return{label:'🟡 進行中',color:'#854F0B',bg:'#FAEEDA'};
  if(pct>=60) return{label:'🟠 待加強',color:'#BA7517',bg:'#FDF3DC'};
  return{label:'🔴 未完成',color:'#A32D2D',bg:'#FCEBEB'};
}
let _hovExpanded=null;
function renderHandover(){
  if(!S.handoverUnits)S.handoverUnits={};
  if(!S.clientData)S.clientData={};
  const today=new Date();today.setHours(0,0,0,0);
  const allUnits=[...new Set(S.rows.map(r=>r.unit).filter(Boolean))];
  const cntDelivered=allUnits.filter(u=>S.handoverUnits[u]&&S.handoverUnits[u].delivered).length;
  const cnt100=allUnits.filter(u=>hoUnitPct(u)===100).length;
  const totalUnits=allUnits.length;
  const delivPct=totalUnits?Math.round(cntDelivered/totalUnits*100):0;

  // ── 顯示控制 ──
  if(!window._hovShow)window._hovShow='all'; // 'all'|'A'|'B'|'shop'
  // showA/showB/showShop 在篩選區後面依 _hovFilter.block 計算

  const batchBar=_hstatsSelected.size>0?`<div style="background:#EEEDFE;border:1px solid #AFA9EC;border-radius:var(--rs);padding:8px 12px;display:flex;align-items:center;gap:8px;margin-bottom:10px;font-size:12px;color:#3C3489;flex-wrap:wrap">
    <strong>已勾選 ${_hstatsSelected.size} 戶</strong>
    <button class="btn btn-p btn-sm" onclick="batchFillInspDate()">批次填寫驗收日</button>
    <button class="btn btn-sm btn-g" onclick="batchMarkDelivered()">批次標記已交屋</button>
    <button class="btn btn-sm" onclick="_hstatsSelected.clear();renderHandover()">✕ 取消</button>
  </div>`:'';

  // ── 格狀單元格 ──
  const MILESTONE_FLOORS=[1,5,10,15,20,25,31];
  function cellHTML(key,floor){
    if(!key)return`<div style="background:transparent;min-height:64px"></div>`;
    // ── 篩選 ──
    const hf2=window._hovFilter||{};
    const huF=S.handoverUnits[key]||{};
    const todayMs=today.getTime();
    if(hf2.planDate==='has'&&!huF.planDate)return`<div style="background:transparent;min-height:64px"></div>`;
    if(hf2.planDate==='none'&&huF.planDate)return`<div style="background:transparent;min-height:64px"></div>`;
    if(hf2.planDate==='d7'){if(!huF.planDate)return`<div style="background:transparent;min-height:64px"></div>`;const dl2=Math.ceil((new Date(huF.planDate)-todayMs)/86400000);if(dl2<0||dl2>7)return`<div style="background:transparent;min-height:64px"></div>`;}
    if(hf2.planDate==='overdue'){if(!huF.planDate)return`<div style="background:transparent;min-height:64px"></div>`;const dl2=Math.ceil((new Date(huF.planDate)-todayMs)/86400000);if(dl2>=0)return`<div style="background:transparent;min-height:64px"></div>`;}
    if(hf2.dateExact&&huF.planDate!==hf2.dateExact)return`<div style="background:transparent;min-height:64px"></div>`;
    if(hf2.type&&(isOwnerUnit(key)?'地主戶':isBizUnit(key)?'業主戶':'自購戶')!==hf2.type)return`<div style="background:transparent;min-height:64px"></div>`;
    const pct=hoUnitPct(unitDisplayName(key))||hoUnitPct(key)||0;
    const grade=hoGrade(pct);
    const hu=S.handoverUnits[key]||{};
    const daysLeft=hu.planDate?Math.ceil((new Date(hu.planDate)-today)/86400000):null;
    const isOwner=isOwnerUnit(key);const isBiz=isBizUnit(key);
    const isSelected=_hstatsSelected.has(key);
    const isExp=_hovExpanded===key;
    const bg=isOwner?'#EEEDFE':isBiz?'#E1F5EE':'var(--surface)';
    const color=isOwner?'#3C3489':isBiz?'#085041':'var(--text2)';
    const outlineStyle=isExp?'outline:2.5px solid var(--purple);':isSelected?'outline:2px solid #185FA5;':'';
    const dispName=unitDisplayName(key).replace(/^[A-Z]\d+-/,'');
    const delivTick=hu.delivered?`<div style="font-size:8px;color:#3B6D11;line-height:1">✓交屋</div>`:'';
    const urgColor=daysLeft!=null?daysLeft<0?'#A32D2D':daysLeft<=3?'#EF9F27':'#185FA5':'';
    const dateTag=hu.planDate?`<div style="font-size:9px;color:${urgColor};line-height:1.1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${hu.planDate.slice(5)}</div>`:'';
    const slotTag=hu.slot?`<div style="font-size:8px;color:var(--text3);line-height:1.1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${hu.slot.split('–')[0]}</div>`:'';
    return`<div onclick="hovCellClick('${esc(key)}')" style="position:relative;background:${bg};color:${color};${outlineStyle}border-radius:3px;border:1px solid rgba(0,0,0,.07);padding:4px 3px 3px;cursor:pointer;text-align:center;line-height:1.2;min-height:64px;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;gap:1px">
      <div style="font-size:11px;font-weight:600">${esc(dispName)}</div>
      <div style="font-size:10px;font-weight:500;color:${grade.color}">${pct}%</div>
      ${dateTag}${slotTag}${delivTick}
      <div style="width:100%;height:3px;background:rgba(0,0,0,.1);border-radius:1px;margin-top:auto"><div style="height:3px;width:${pct}%;background:${grade.color};border-radius:1px"></div></div>
    </div>`;
  }

  // ── 欄標與格狀表 ──
  const MILESTONE_BELOW_H=new Set([5,10,15,20,25,31]);
  function buildGrid(rawData,cols,blockId){
    const colHdrs=cols.map(c=>`<div style="font-size:13px;text-align:center;color:var(--text2);font-weight:600;padding:3px 0">${c}</div>`).join('');
    const gridCols=`28px repeat(${cols.length},1fr)`;
    const rows=G95_FLOORS.map(fl=>{
      const flNum=Number(fl);
      const addSep=MILESTONE_BELOW_H.has(flNum);
      const cells=cols.map(col=>{
        const raw=rawData[col];
        return cellHTML(raw?raw[fl]:null,fl);
      }).join('');
      return`<div style="display:contents">
        <div style="font-size:12px;color:var(--text3);text-align:right;padding-right:4px;display:flex;align-items:flex-start;justify-content:flex-end;padding-top:4px;font-weight:500">${fl}</div>
        ${cells}
      </div>
      ${addSep?`<div style="grid-column:1/-1;height:0;border-bottom:2.5px solid #C8C5C0;margin:2px 0"></div>`:''}`;
    }).join('');
    return`<div>
      <div style="display:grid;grid-template-columns:${gridCols};gap:4px;margin-bottom:4px">
        <div></div>${colHdrs}
      </div>
      <div style="display:grid;grid-template-columns:${gridCols};gap:4px">
        ${rows}
      </div>
    </div>`;
  }

  // ── 店鋪格 ──
  function buildShopGrid(){
    const shops=[
      {key:'地A1-1',col:'店A1'},{key:'A2-1',col:'店A2'},{key:'A3-1',col:'店A3'},
      {key:'業A5-1',col:'店A5'},{key:'地A6-1',col:'店A6'},{key:'地A7-1',col:'店A7'},
      {key:'地A8-1',col:'店A8'},{key:'地A9-1',col:'店A9'},{key:'地A10-1',col:'店A10'},
      {key:'地A11-1',col:'店A11'},{key:'地A12-1',col:'店A12'},{key:'地A15-1',col:'店A15'},
      {key:'地A16-1',col:'店A16'},{key:'地A17-1',col:'店A17'},{key:'地A18-1',col:'店A18'},
      {key:'地A19-1',col:'店A19'},{key:'地A20-1',col:'店A20'},{key:'地A21-1',col:'店A21'},
      {key:'地A22-1',col:'店A22'},{key:'地A23-1',col:'店A23'},{key:'地A25-1',col:'店A25'},
      {key:'地A26-1',col:'店A26'},{key:'地A27-1',col:'店A27'},{key:'業A28-1',col:'店A28'},
      {key:'地A29-1',col:'店A29'},{key:'業A30-1',col:'店A30'},{key:'業C2-1',col:'店C2'},
      {key:'地C1-2',col:'店C1(2F)'},
    ];
    const SHOP_COLS_PER_ROW=7;
    const rows=[];
    for(let i=0;i<shops.length;i+=SHOP_COLS_PER_ROW){
      const chunk=shops.slice(i,i+SHOP_COLS_PER_ROW);
      const hdr=chunk.map(({col})=>`<div style="font-size:13px;text-align:center;color:var(--text2);font-weight:600;padding:3px 0">${col}</div>`).join('');
      const cells=chunk.map(({key,col:shopCol})=>{
        const pct=hoUnitPct(unitDisplayName(key))||hoUnitPct(key)||0;
        const grade=hoGrade(pct);
        const hu=S.handoverUnits[key]||{};
        const isOwner=isOwnerUnit(key);const isBiz=isBizUnit(key);
        const bg=isOwner?'#EEEDFE':isBiz?'#E1F5EE':'var(--surface)';
        const color=isOwner?'#3C3489':isBiz?'#085041':'var(--text2)';
        const isExp=_hovExpanded===key;
        const isSelected=_hstatsSelected.has(key);
        const outlineStyle=isExp?'outline:2.5px solid var(--purple);':isSelected?'outline:2px solid #185FA5;':'';
        const dispLabel=shopCol||unitDisplayName(key).replace(/^[A-Z]\d*-/,'');
        const daysLeft=hu.planDate?Math.ceil((new Date(hu.planDate)-today)/86400000):null;
        const delivTick=hu.delivered?`<div style="font-size:8px;color:#3B6D11;line-height:1">✓交屋</div>`:'';
        const urgColor=daysLeft!=null?daysLeft<0?'#A32D2D':daysLeft<=3?'#EF9F27':'#185FA5':'';
        const dateTag=hu.planDate?`<div style="font-size:9px;color:${urgColor};line-height:1.1">${hu.planDate.slice(5)}</div>`:'';
        const slotTag=hu.slot?`<div style="font-size:8px;color:var(--text3);line-height:1.1">${hu.slot.split('–')[0]}</div>`:'';
        return`<div onclick="hovCellClick('${esc(key)}')" style="background:${bg};color:${color};${outlineStyle}border-radius:3px;border:1px solid rgba(0,0,0,.07);padding:4px 3px 3px;cursor:pointer;text-align:center;line-height:1.2;min-height:64px;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;gap:1px">
          <div style="font-size:11px;font-weight:600">${esc(dispLabel)}</div>
          <div style="font-size:10px;font-weight:500;color:${grade.color}">${pct}%</div>
          ${dateTag}${slotTag}${delivTick}
          <div style="width:100%;height:3px;background:rgba(0,0,0,.1);border-radius:1px;margin-top:auto"><div style="height:3px;width:${pct}%;background:${grade.color};border-radius:1px"></div></div>
        </div>`;
      }).join('');
      rows.push(`<div style="display:grid;grid-template-columns:repeat(${chunk.length},1fr);gap:4px;margin-bottom:3px">${hdr}</div>
        <div style="display:grid;grid-template-columns:repeat(${chunk.length},1fr);gap:4px;margin-bottom:10px">${cells}</div>`);
    }
    return rows.join('');
  }

  // ── 展開卡片 ──
  function buildExpandCard(){
    const key=_hovExpanded;
    if(!key)return'';
    const hu=S.handoverUnits[key]||{};
    const cl=S.clientData[key]||{};
    const pct=hoUnitPct(unitDisplayName(key))||hoUnitPct(key);
    const grade=hoGrade(pct);
    const insps=hu.inspections||[];
    const inspCols=insps.map((ins,i)=>{
      const isDone=!!ins.date;
      return`<div style="display:flex;flex-direction:column;gap:2px">
        <span style="font-size:10px;color:var(--text2)">${esc(ins.label)}</span>
        <div style="display:flex;align-items:center;gap:3px">
          <input type="date" value="${esc(ins.date||'')}" onchange="setHuFieldH('${esc(key)}',${i},this.value)" style="font-size:11px;padding:3px 5px;border:1px solid var(--border);border-radius:var(--rs);font-family:var(--font);${isDone?'color:var(--green);border-color:var(--green)':''}">
          <button class="btn btn-sm btn-d" onclick="delHuInspH2('${esc(key)}',${i})" style="padding:2px 4px;font-size:10px">—</button>
        </div>
      </div>`;
    }).join('');
    return`<div style="background:#F7F5FF;border:2px solid var(--purple);border-radius:var(--r);padding:12px 14px;margin-bottom:10px;animation:tIn .15s ease">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap">
        <span style="font-size:13px;font-weight:600">${esc(key)}</span>
        <span style="padding:2px 8px;border-radius:20px;font-size:10px;font-weight:600;background:${grade.bg};color:${grade.color}">${pct??'—'}%</span>
        ${hu.delivered?`<span style="padding:1px 8px;border-radius:20px;font-size:10px;background:#EAF3DE;color:#3B6D11">🏠 已交屋</span>`:''}
        <button class="btn btn-sm" onclick="_hovExpanded=null;renderHandover()">✕</button>
        <button class="btn btn-sm btn-g" onclick="toggleDeliveredH('${esc(key)}')">${hu.delivered?'取消交屋':'🏠 已交屋'}</button>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px">
        <div><span style="font-size:10px;color:var(--text2)">客戶姓名</span><br><input value="${esc(cl.name||'')}" placeholder="姓名" onchange="setCl('${esc(key)}','name',this.value)" style="width:100%;font-size:12px;padding:4px 6px;border:1px solid var(--border);border-radius:var(--rs);font-family:var(--font);margin-top:2px"></div>
        <div><span style="font-size:10px;color:var(--text2)">電話</span><br><input value="${esc(cl.tel||'')}" placeholder="電話" onchange="setCl('${esc(key)}','tel',this.value)" style="width:100%;font-size:12px;padding:4px 6px;border:1px solid var(--border);border-radius:var(--rs);font-family:var(--font);margin-top:2px"></div>
      </div>
      <div style="display:flex;align-items:flex-end;gap:6px;flex-wrap:wrap">
        <div style="display:flex;flex-direction:column;gap:2px">
          <span style="font-size:10px;color:var(--text2)">預定驗收</span>
          <input type="date" value="${esc(hu.planDate||'')}" onchange="setHuField('${esc(key)}','planDate',this.value)" style="font-size:12px;padding:4px 6px;border:1px solid var(--border);border-radius:var(--rs);font-family:var(--font)">
        </div>
        ${inspCols}
        <button class="btn btn-sm" onclick="addHuInspH2('${esc(key)}')" style="padding:3px 8px;align-self:flex-end">＋</button>
      </div>
      <div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--border2)">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
          <span style="font-size:11px;font-weight:600">📋 缺失清單</span>
          ${(()=>{const dn=unitDisplayName(key);const dr=S.rows.filter(r=>r.unit===dn||r.unit===key);const dt=dr.length;const dp=dr.filter(r=>!r.actualDone).length;return dt?`<span style="padding:1px 8px;border-radius:20px;font-size:10px;background:${dp>0?'#FCEBEB':'#EAF3DE'};color:${dp>0?'#791F1F':'#3B6D11'};font-weight:600">缺失 ${dp}/${dt}</span>`:''})()}
          <button class="btn btn-sm btn-pdf no-print" onclick="printUnitDefects('${esc(key)}')" style="margin-left:auto;font-size:10px">🖨 PDF</button>
        </div>
        ${buildUnitDefectTable(key)}
      </div>
    </div>`;
  }

  if(!window._hovFilter)window._hovFilter={planDate:'',dateExact:'',type:'',floors:new Set(),cols:new Set(),block:'all'};
  if(!window._hovFilter.block)window._hovFilter.block='all';
  const hf=window._hovFilter;
  const _dateLabel2=hf.dateExact?`📅 ${hf.dateExact}`:'選取日期';
  const hfBlock=hf.block||'all';
  // 棟別篩選覆蓋 _hovShow
  const showA=(window._hovShow==='all'||window._hovShow==='A')&&(hfBlock==='all'||hfBlock==='A');
  const showB=(window._hovShow==='all'||window._hovShow==='B')&&(hfBlock==='all'||hfBlock==='B');
  const showShop=(window._hovShow==='all'||window._hovShow==='shop')&&(hfBlock==='all'||hfBlock==='shop');
  const viewBtns=['all','A','B','shop'].map(v=>`<button class="btn btn-sm${window._hovShow===v?' btn-p':''}" onclick="window._hovShow='${v}';renderHandover()" style="font-size:11px">${{all:'全部',A:'A棟',B:'B棟',shop:'店鋪'}[v]}</button>`).join('');

  document.getElementById('pane-handover').innerHTML=`
    <div style="display:flex;gap:7px;align-items:center;margin-bottom:8px;flex-wrap:wrap">
      <div class="stats" style="flex:1;min-width:0;margin-bottom:0">
        <div class="stat"><div class="stat-l">可交屋100%</div><div class="stat-v" style="color:var(--green)">${cnt100}</div></div>
        <div class="stat" style="border:2px solid var(--green)"><div class="stat-l">🏠 已交屋</div><div class="stat-v" style="color:var(--green)">${cntDelivered}<span style="font-size:11px;font-weight:400"> / ${totalUnits}（${delivPct}%）</span></div></div>
      </div>
      <div style="display:flex;gap:5px">${viewBtns}</div>
      <button class="btn btn-pdf no-print" onclick="printHandoverPdf()">🖨 PDF</button>
    </div>
    <div style="display:flex;gap:7px;align-items:center;margin-bottom:10px;flex-wrap:wrap;padding:7px 8px;background:var(--surface);border-radius:var(--rs)">
      <span style="font-size:11px;color:var(--text2);flex-shrink:0">篩選：</span>
      <select onchange="window._hovFilter.planDate=this.value;renderHandover()" style="font-size:11px;padding:4px 7px;border:1px solid var(--border);border-radius:var(--rs);background:var(--card);color:var(--text);font-family:var(--font)">
        <option value="" ${hf.planDate===''?'selected':''}>預定驗收日</option>
        <option value="has" ${hf.planDate==='has'?'selected':''}>已設定驗收日</option>
        <option value="none" ${hf.planDate==='none'?'selected':''}>未設定驗收日</option>
        <option value="d7" ${hf.planDate==='d7'?'selected':''}>7天內驗收</option>
        <option value="overdue" ${hf.planDate==='overdue'?'selected':''}>驗收日已逾期</option>
      </select>
      <div style="position:relative;display:inline-block">
        <button class="btn btn-sm no-print${hf.dateExact?' btn-p':''}" onclick="toggleHovDatePicker(this)" id="hov-date-btn" style="font-size:11px">${_dateLabel2}</button>
        <div id="hov-date-picker" style="display:none;position:absolute;top:calc(100% + 3px);left:0;background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:10px;z-index:100;box-shadow:0 4px 20px rgba(0,0,0,.14)">
          <div style="font-size:11px;color:var(--text2);margin-bottom:6px">選擇驗收日期：</div>
          <input type="date" id="hov-date-inp" value="${esc(hf.dateExact||'')}" style="font-size:13px;padding:5px 8px;border:1px solid var(--border);border-radius:var(--rs);font-family:var(--font);width:160px">
          <div style="display:flex;gap:6px;margin-top:8px">
            <button class="btn btn-p btn-sm" onclick="window._hovFilter.dateExact=document.getElementById('hov-date-inp').value;document.getElementById('hov-date-picker').style.display='none';renderHandover()">套用</button>
            <button class="btn btn-sm" onclick="window._hovFilter.dateExact='';document.getElementById('hov-date-picker').style.display='none';renderHandover()">清除</button>
          </div>
        </div>
      </div>
      <select onchange="window._hovFilter.type=this.value;renderHandover()" style="font-size:11px;padding:4px 7px;border:1px solid var(--border);border-radius:var(--rs);background:var(--card);color:var(--text);font-family:var(--font)">
        <option value="" ${hf.type===''?'selected':''}>類別</option>
        <option value="地主戶" ${hf.type==='地主戶'?'selected':''}>地主戶</option>
        <option value="自購戶" ${hf.type==='自購戶'?'selected':''}>自購戶</option>
        <option value="業主戶" ${hf.type==='業主戶'?'selected':''}>業主戶</option>
      </select>
      <span style="font-size:11px;color:var(--text2);margin-left:6px">棟別：</span>
      ${['all','A','B','shop'].map(b=>{
        const v=window._hovFilter.block||'all';
        const active=v===b;
        return`<button onclick="window._hovFilter.block='${b}';renderHandover()" style="font-size:11px;padding:2px 9px;border:1px solid ${active?'var(--purple)':'var(--border)'};background:${active?'#F0EEFF':'var(--card)'};color:${active?'var(--purple)':'var(--text2)'};border-radius:3px;cursor:pointer;margin-right:2px">${{all:'全部',A:'A棟',B:'B棟',shop:'店鋪'}[b]}</button>`;
      }).join('')}
      ${(hf.planDate||hf.dateExact||hf.type||(hf.block&&hf.block!=='all'))?`<button class="btn btn-sm" onclick="window._hovFilter={planDate:'',dateExact:'',type:'',floors:new Set(),cols:new Set(),block:'all'};renderHandover()" style="font-size:11px;color:var(--red)">✕ 清除篩選</button>`:''}
    </div>
    ${batchBar}
    ${buildExpandCard()}
    <div style="display:grid;grid-template-columns:${showA&&showB?'1fr 1fr':(showA||showB)?'1fr':''} ${showShop?'auto':''};gap:14px;align-items:start">
