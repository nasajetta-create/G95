  const colLabel=fUnitCols.size>0?`戶別（已選 ${fUnitCols.size}）`:'戶別';
  const planDateLabel=fPlanDate?({has:'已設驗收日',none:'未設驗收日',overdue:'驗收日逾期',d7:'7天內驗收'}[fPlanDate]||'預定驗收日'):'預定驗收日';
  const allUnitCols=[...G95_A_COLS,...G95_B_COLS];

  // ── Build card list: A棟 | B棟 ────────────────────────────────────────
  const today=new Date();today.setHours(0,0,0,0);
  function buildUnitCard(key,floor,colId,blockId){
    if(!key)return'';
    const flStr=String(floor);
    if(fFloors.size>0&&!fFloors.has(flStr))return'';
    if(fBlock.size>0&&blockId&&!fBlock.has(blockId))return'';
    if(fUnitCols.size>0&&colId&&!fUnitCols.has(colId))return'';
    const uType=isOwnerK(key)?'地主戶':isBizK(key)?'業主戶':'自購戶';
    if(fType&&uType!==fType)return'';
    // 預定驗收日篩選
    if(fPlanDate){
      const hu2=S.handoverUnits[key]||{};
      if(fPlanDate==='has'&&!hu2.planDate)return'';
      if(fPlanDate==='none'&&hu2.planDate)return'';
      if(fPlanDate==='overdue'){if(!hu2.planDate)return'';const dl=Math.ceil((new Date(hu2.planDate)-today2)/86400000);if(dl>=0)return'';}
      if(fPlanDate==='d7'){if(!hu2.planDate)return'';const dl=Math.ceil((new Date(hu2.planDate)-today2)/86400000);if(dl<0||dl>7)return'';}
    }
    // 精確日期篩選
    if(fDateExact){const hu2=S.handoverUnits[key]||{};if(hu2.planDate!==fDateExact)return'';}
    // 時段篩選
    const _ts=window._hstatsTs;
    if(_ts&&_ts.size>0){const hu2=S.handoverUnits[key]||{};if(!_ts.has(hu2.slot||''))return'';}
    const hu=S.handoverUnits[key]||{};
    const cl=S.clientData[key]||{};
    const displayName=unitDisplayName(key);
    const pct=hoUnitPct(displayName)||hoUnitPct(key);
    const grade=hoGrade(pct);
    const daysLeft=hu.planDate?Math.ceil((new Date(hu.planDate)-today)/86400000):null;
    const overdueInsp=hu.planDate&&daysLeft<0&&!hu.delivered;
    const urgentInsp=hu.planDate&&daysLeft!=null&&daysLeft>=0&&daysLeft<=3&&!hu.delivered;
    const isExp=_expandedUnit===key;
    const isOwner=isOwnerK(key);const isBiz=isBizK(key);
    const typeBg=isOwner?'background:#EEEDFE;':isBiz?'background:#E1F5EE;':'background:var(--card);';
    const cardBorder=isExp?'border:2px solid var(--purple);':'border:1px solid var(--border);';
    let warnHtml='';
    if(hu.planDate){
      if(overdueInsp) warnHtml=`<div style="margin-top:5px;font-size:10px;color:#791F1F;background:#FCEBEB;border-radius:4px;padding:3px 7px;display:flex;align-items:center;gap:4px">⚠ 驗收日 ${hu.planDate} — 還有 ${daysLeft} 天，完成度不足</div>`;
