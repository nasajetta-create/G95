}
function renderMgr(){
  const TITLE_ORDER=['副理','所長','主任','組長','工程師','其他',''];
  function titleRank(t){const i=TITLE_ORDER.indexOf(t||'');return i<0?TITLE_ORDER.length-1:i;}
  const mgrSort=window._mgrSort||'manual';
  let sortedMgrs=[...S.managers];
  if(mgrSort==='az')sortedMgrs.sort((a,b)=>a.localeCompare(b,'zh-TW'));
  else if(mgrSort==='duty_z')sortedMgrs.sort((a,b)=>{const ra=S.rows.filter(r=>r.manager===a).length,rb=S.rows.filter(r=>r.manager===b).length;return rb-ra;});
  else if(mgrSort==='over_z')sortedMgrs.sort((a,b)=>{const oa=S.rows.filter(r=>r.manager===a&&getStatus(r)==='overdue').length,ob=S.rows.filter(r=>r.manager===b&&getStatus(r)==='overdue').length;return ob-oa;});
  else if(mgrSort==='title')sortedMgrs.sort((a,b)=>titleRank((S.managerDetails[a]||{}).title)-titleRank((S.managerDetails[b]||{}).title));
  const sortBtns=[
    {v:'manual',l:'手動排序'},
    {v:'az',l:'筆劃 A→Z'},
    {v:'duty_z',l:'負責項目 Z→A'},
    {v:'over_z',l:'逾期項目 Z→A'},
    {v:'title',l:'職位高→低'},
  ].map(({v,l})=>`<button onclick="window._mgrSort='${v}';renderMgr()" style="font-size:11px;padding:2px 9px;border:1px solid ${mgrSort===v?'var(--purple)':'var(--border)'};background:${mgrSort===v?'#F0EEFF':'var(--card)'};color:${mgrSort===v?'var(--purple)':'var(--text2)'};border-radius:3px;cursor:pointer;margin-right:3px">${l}</button>`).join('');
  const mCards=sortedMgrs.map(m=>{
    const mRows=S.rows.filter(r=>r.manager===m);
