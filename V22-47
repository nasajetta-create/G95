// ── 分頁工具函式 ────────────────────────────────────────────────────────────
function pgBarHTML(total, page, onClickFn){
  const pages=Math.max(1,Math.ceil(total/PAGE_SIZE));
  if(pages<=1)return '';
  const start=page*PAGE_SIZE+1, end=Math.min((page+1)*PAGE_SIZE,total);
  let btns='';
  // 上一頁
  btns+=`<button class="pg-btn no-print" ${page===0?'disabled':''} onclick="${onClickFn}(${page-1})">‹</button>`;
  // 頁碼按鈕（顯示前2、當前±2、後2）
  const show=new Set([0,1,page-2,page-1,page,page+1,page+2,pages-2,pages-1].filter(p=>p>=0&&p<pages));
  let prev=-1;
  [...show].sort((a,b)=>a-b).forEach(p=>{
    if(prev>=0&&p-prev>1)btns+='<span class="pg-info">…</span>';
    btns+=`<button class="pg-btn no-print${p===page?' active':''}" onclick="${onClickFn}(${p})">${p+1}</button>`;
    prev=p;
  });
  // 下一頁
  btns+=`<button class="pg-btn no-print" ${page>=pages-1?'disabled':''} onclick="${onClickFn}(${page+1})">›</button>`;
  btns+=`<span class="pg-info">${start}–${end} / 共 ${total} 筆</span>`;
  // 快速跳頁
  btns+=`<input type="number" min="1" max="${pages}" value="${page+1}" onchange="gotoMainPage(this.value-1,${pages})" style="width:48px;font-size:11px;padding:3px 5px;border:1px solid var(--border);border-radius:6px;text-align:center;font-family:var(--font)" title="跳至頁數">`;
  return `<div class="pg-bar">${btns}</div>`;
}
function setMainPage(p){mainPage=p;renderMain();}
function gotoMainPage(p,max){mainPage=Math.max(0,Math.min(p,max-1));renderMain();}

