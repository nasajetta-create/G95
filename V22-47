// ── 客戶清單：暫存編輯緩衝區（確認前不寫入 S.clientData）────────────────
let _clientExpanded=null;
let _clEditBuf={};        // {key: {name,tel,type,note,parkings}}
let _clSelected=new Set(); // 多選 keys

function renderClients(){
  if(!S.clientData)S.clientData={};
  // ── 頂部統計卡片：以 S.clientData[key].type 為準，未設定才用 key 前綴推斷 ──
  function getUnitType(k){
    const cd=S.clientData&&S.clientData[k];
    if(cd&&cd.type)return cd.type;
    if(k&&k.startsWith('地'))return'地主戶';
    if(k&&k.startsWith('業'))return'業主戶';
    return'自購戶';
  }
  function countBlockByType(rawData,typeName){
    return Object.values(rawData).reduce((s,col)=>s+Object.values(col).filter(k=>k&&getUnitType(k)===typeName).length,0);
  }
  const shopKeys=['地A1-1','A2-1','A3-1','業A5-1','地A6-1','地A7-1','地A8-1','地A9-1','地A10-1','地A11-1','地A12-1','地A15-1','地A16-1','地A17-1','地A18-1','地A19-1','地A20-1','地A21-1','地A22-1','地A23-1','地A25-1','地A26-1','地A27-1','業A28-1','地A29-1','業A30-1','業C2-1','地C1-2'];
  const cntAOwner=countBlockByType(G95_RAW_A,'地主戶'),cntABiz=countBlockByType(G95_RAW_A,'業主戶'),cntANorm=countBlockByType(G95_RAW_A,'自購戶');
  const cntBOwner=countBlockByType(G95_RAW_B,'地主戶'),cntBBiz=countBlockByType(G95_RAW_B,'業主戶'),cntBNorm=countBlockByType(G95_RAW_B,'自購戶');
  const cntShopOwner=shopKeys.filter(k=>getUnitType(k)==='地主戶').length;
  const cntShopBiz=shopKeys.filter(k=>getUnitType(k)==='業主戶').length;
  const cntShopNorm=shopKeys.filter(k=>getUnitType(k)==='自購戶').length;
  const totalA=cntAOwner+cntANorm+cntABiz,totalB=cntBOwner+cntBNorm+cntBBiz,totalShop=cntShopOwner+cntShopNorm+cntShopBiz;
  const total=totalA+totalB+totalShop;
  const statCard=(label,bg,color,detail)=>`<div style="background:${bg};border-radius:var(--r);padding:8px 12px;flex:1;min-width:140px"><div style="font-size:11px;font-weight:600;color:${color};margin-bottom:4px">${label}</div><div style="font-size:18px;font-weight:700;color:${color}">${detail.total}</div><div style="font-size:10px;color:${color};opacity:.75;margin-top:2px">A棟 ${detail.a} ／ B棟 ${detail.b} ／ 店鋪 ${detail.s}</div></div>`;
  const statsBar=`<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px">
    <div style="background:var(--surface);border-radius:var(--r);padding:8px 12px;flex:1;min-width:100px;text-align:center"><div style="font-size:11px;color:var(--text2)">總戶數</div><div style="font-size:22px;font-weight:700;color:var(--text)">${total}</div><div style="font-size:10px;color:var(--text3)">A棟 ${totalA} ／ B棟 ${totalB} ／ 店鋪 ${totalShop}</div></div>
    ${statCard('🏛 地主戶','#EEEDFE','#3C3489',{total:cntAOwner+cntBOwner+cntShopOwner,a:cntAOwner,b:cntBOwner,s:cntShopOwner})}
    ${statCard('🏠 自購戶','var(--surface)','var(--text2)',{total:cntANorm+cntBNorm+cntShopNorm,a:cntANorm,b:cntBNorm,s:cntShopNorm})}
    ${statCard('🏢 業主戶','#E1F5EE','#085041',{total:cntABiz+cntBBiz+cntShopBiz,a:cntABiz,b:cntBBiz,s:cntShopBiz})}
  </div>`;

  const search=((document.getElementById('cl-search')||{}).value||'').trim().toLowerCase();
  const fType=(document.getElementById('cl-type')||{}).value||'';
  const fBlock=(document.getElementById('cl-block')||{}).value||'';

  // 批次操作列
  const batchBar=_clSelected.size>0?`<div style="background:#EEEDFE;border:1px solid #AFA9EC;border-radius:var(--rs);padding:8px 12px;display:flex;align-items:center;gap:8px;margin-bottom:10px;font-size:12px;color:#3C3489;flex-wrap:wrap">
    <strong>已選 ${_clSelected.size} 戶</strong>
    <button class="btn btn-p btn-sm" onclick="showBatchClientEdit()">✏️ 批次修改</button>
    <button class="btn btn-sm" onclick="_clSelected.clear();renderClients()">✕ 取消</button>
  </div>`:'';

  // 格子建構（含就地展開）
  function makeCell(key){
    if(!key)return`<span style="background:transparent;display:block;padding:3px 2px"></span>`;
    const cl=S.clientData[key]||{};
    const nameMatch=search&&cl.name&&cl.name.toLowerCase().includes(search);
    const keyMatch=search&&key.toLowerCase().includes(search);
    const parkMatch=search&&(cl.parkings||[]).some(p=>p.toLowerCase().includes(search));
    const hidden=search&&!nameMatch&&!keyMatch&&!parkMatch;
    if(hidden)return`<span style="background:transparent;display:block;padding:3px 2px"></span>`;
    const typeMatch=fType&&(getUnitType(key))!==fType;
    if(typeMatch)return`<span style="background:transparent;display:block;padding:3px 2px"></span>`;
    const blockId=key.match(/^(地|業)?([AB])/)?.[2];
    const blockMatch=fBlock&&blockId!==fBlock;
    if(blockMatch)return`<span style="background:transparent;display:block;padding:3px 2px"></span>`;
    const isExp=_clientExpanded===key;
    const isSel=_clSelected.has(key);
    const pct=hoUnitPct(key)||hoUnitPct(unitDisplayName(key));
    const pctBar=pct!=null?`<div style="margin-top:2px;height:3px;background:rgba(0,0,0,.1);border-radius:2px"><div style="height:3px;width:${pct}%;background:${pct===100?'#3B6D11':pct>=80?'#EF9F27':'#A32D2D'};border-radius:2px"></div></div>`:'';
    const selRing=isSel?'outline:2px solid #185FA5;':'';
    const expRing=isExp?'outline:2.5px solid var(--purple);':'';
    return`<span onclick="clientCellClick('${esc(key)}',event)" title="${esc(key)}${cl.name?' - '+esc(cl.name):''}" style="display:block;padding:5px 3px;border-radius:4px;cursor:pointer;border:0.5px solid transparent;${cellBg(key)};${selRing||expRing}font-size:11px;text-align:center;line-height:1.3;position:relative">
      ${isSel?`<span style="position:absolute;top:0;left:0;font-size:8px;color:#185FA5">✓</span>`:''}
      <div style="font-size:11px;font-weight:500">${unitDisplayName(key).replace(/^[A-Z][0-9]+-/,'')}</div>
      ${cl.name?`<div style="font-size:9px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;opacity:.75">${esc(cl.name)}</div>`:''}
      ${pctBar}
    </span>`;
  }

  function buildClientCol(rawData,cols,title){
    const header=`<div style="font-size:12px;font-weight:600;color:var(--text2);padding:5px 8px;background:var(--surface);border-radius:var(--rs);margin-bottom:5px">${title}</div>`;
    const rows=G95_FLOORS.map(fl=>{
      // 若此行有展開的格子，在行下方插入展開卡片
      const cells=cols.map(col=>{
        const raw=rawData[col];
        return makeCell(raw?raw[fl]:null);
      });
      const expandKey=cols.map(col=>{const raw=rawData[col];return raw?raw[fl]:null;}).find(k=>k&&_clientExpanded===k);
      const expandDiv=expandKey?`<div style="display:grid;grid-column:1/-1"><div id="cl-detail-${esc(expandKey)}">${buildClientDetailInline(expandKey)}</div></div>`:'';
      return`<div style="display:grid;grid-template-columns:26px repeat(${cols.length},1fr);gap:2px;align-items:start;margin-bottom:2px">
        <span style="font-size:10px;color:var(--text3);text-align:right;padding-right:3px;padding-top:6px">${fl}</span>${cells.join('')}
      </div>${expandDiv}`;
    }).join('');
    return`<div style="flex:1;min-width:0">${header}<div style="display:grid;grid-template-columns:26px repeat(${cols.length},1fr);gap:2px;margin-bottom:4px"><span></span>${cols.map(c=>`<span style="font-size:11px;text-align:center;color:var(--text2);font-weight:500">${c}</span>`).join('')}</div>${rows}</div>`;
  }

  document.getElementById('pane-clients').innerHTML=`
    ${statsBar}
    <div style="display:flex;gap:8px;align-items:center;margin-bottom:10px;flex-wrap:wrap">
      <input id="cl-search" type="text" placeholder="搜尋戶別 / 姓名 / 車位…" value="${esc(search)}" oninput="renderClients()" style="font-size:12px;padding:5px 9px;border:1px solid var(--border);border-radius:var(--rs);font-family:var(--font);width:200px">
      <select id="cl-type" onchange="renderClients()" style="font-size:12px;padding:5px 9px;border:1px solid var(--border);border-radius:var(--rs);background:var(--card);color:var(--text);font-family:var(--font)">
        <option value="">全部類型</option><option value="地主戶">地主戶</option><option value="業主戶">業主戶</option><option value="自購戶">自購戶</option>
      </select>
      <select id="cl-block" onchange="renderClients()" style="font-size:12px;padding:5px 9px;border:1px solid var(--border);border-radius:var(--rs);background:var(--card);color:var(--text);font-family:var(--font)">
        <option value="">全部棟別</option><option value="A">A棟</option><option value="B">B棟</option>
      </select>
      <button class="btn btn-sm no-print" onclick="document.getElementById('cl-import-inp').click()" style="background:#E8E0F8;color:#3C3489;border-color:#C4B8F0">📂 匯入 Excel</button>
      <input type="file" id="cl-import-inp" accept=".xlsx,.xls,.csv" style="display:none" onchange="importClientExcel(this.files[0]);this.value=''">
      <button class="btn btn-sm no-print" onclick="downloadClientTemplate()" style="background:#E8F0FE;color:#185FA5;border-color:#B5D4F4">⬇ 範本</button>
      <div style="display:flex;gap:5px;font-size:11px;flex-wrap:wrap;margin-left:4px">
        <span style="display:flex;align-items:center;gap:3px"><span style="width:9px;height:9px;border-radius:2px;background:#EEEDFE;border:0.5px solid #AFA9EC;display:inline-block"></span>地主戶</span>
        <span style="display:flex;align-items:center;gap:3px"><span style="width:9px;height:9px;border-radius:2px;background:#E1F5EE;border:0.5px solid #9FE1CB;display:inline-block"></span>業主戶</span>
        <span style="display:flex;align-items:center;gap:3px"><span style="width:9px;height:9px;border-radius:2px;background:var(--surface);display:inline-block"></span>自購戶</span>
      </div>
      <button class="btn btn-pdf btn-sm no-print" onclick="printClients()" style="margin-left:auto">🖨 PDF</button>
    </div>
    ${batchBar}
    <div style="display:flex;gap:10px">
      ${buildClientCol(G95_RAW_A,G95_A_COLS,'A 棟')}
      ${buildClientCol(G95_RAW_B,G95_B_COLS,'B 棟')}
    </div>
    ${buildClientShop()}`;
  setTimeout(()=>{
    const s=document.getElementById('cl-search');if(s)s.value=search;
    const t=document.getElementById('cl-type');if(t)t.value=fType;
    const b=document.getElementById('cl-block');if(b)b.value=fBlock;
  },0);
}

// ── 格子點擊：長按或 Ctrl 多選，單擊展開 ──────────────────────────────
function clientCellClick(key,e){
  if(e.ctrlKey||e.metaKey||e.shiftKey||_clSelected.size>0){
    // 多選模式
    _clSelected.has(key)?_clSelected.delete(key):_clSelected.add(key);
    renderClients();return;
  }
  // 單選展開
  _clientExpanded=(_clientExpanded===key)?null:key;
  if(_clientExpanded){
    // 初始化編輯緩衝區
    const cl=S.clientData[key]||{};
    _clEditBuf[key]={
      name:cl.name||'',tel:cl.tel||'',
      type:cl.type||(isOwnerUnit(key)?'地主戶':isBizUnit(key)?'業主戶':'自購戶'),
      note:cl.note||'',parkings:[...(cl.parkings||[])]
    };
  }
  renderClients();
  // 滾動到展開位置（不跳回頂部）
  requestAnimationFrame(()=>{
    const el=document.getElementById('cl-detail-'+key);
    if(el)el.scrollIntoView({behavior:'smooth',block:'nearest'});
  });
}

// ── 就地展開的編輯卡片（使用緩衝區，不即時寫入）─────────────────────
