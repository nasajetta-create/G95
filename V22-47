    +'<input type="date" value="'+esc(ev.actualEnd)+'" onchange="updEvent('+ev.id+',\'actualEnd\',this.value)" style="width:110px;'+aeStyle+'">'
    +'<span class="dow-lbl">'+dowStr(ev.actualEnd)+'</span></div>'
