  // ── 共用格子建構器 ───────────────────────────────────────────────────
  const today3=new Date();today3.setHours(0,0,0,0);
  function makeGridCell(key,fl,col,blockId,extraStyle){
    if(!key)return`<div style="background:transparent;min-height:64px"></div>`;
    const hu=S.handoverUnits[key]||{};
    // 篩選
    if(fFloors.size>0&&!fFloors.has(String(fl)))return`<div style="background:transparent;min-height:64px"></div>`;
    if(fUnitCols.size>0&&col&&!fUnitCols.has(col))return`<div style="background:transparent;min-height:64px"></div>`;
    if(fType&&(isOwnerK(key)?'地主戶':isBizK(key)?'業主戶':'自購戶')!==fType)return`<div style="background:transparent;min-height:64px"></div>`;
    if(fPlanDate==='has'&&!hu.planDate)return`<div style="background:transparent;min-height:64px"></div>`;
    if(fPlanDate==='none'&&hu.planDate)return`<div style="background:transparent;min-height:64px"></div>`;
    if(fDateExact&&hu.planDate!==fDateExact)return`<div style="background:transparent;min-height:64px"></div>`;
    const _ts=window._hstatsTs;if(_ts&&_ts.size>0&&!_ts.has(hu.slot||''))return`<div style="background:transparent;min-height:64px"></div>`;
    const bg=isOwnerK(key)?'#EEEDFE':isBizK(key)?'#E1F5EE':'var(--surface)';
    const color=isOwnerK(key)?'#3C3489':isBizK(key)?'#085041':'var(--text2)';
    const isExp=_expandedUnit===key;
    const isSel=_hstatsSelected.has(key);
    const outlineStyle=isExp?'outline:2.5px solid var(--purple);':isSel?'outline:2px solid #185FA5;':'';
    const dispName=col||unitDisplayName(key).replace(/^[A-Z]\d+-/,'');
    const pct=hoUnitPct(unitDisplayName(key))||hoUnitPct(key)||0;
    const grade=hoGrade(pct);
    const daysLeft=hu.planDate?Math.ceil((new Date(hu.planDate)-today3)/86400000):null;
    const delivTick=hu.delivered?`<div style="font-size:8px;color:#3B6D11;line-height:1">✓交屋</div>`:'';
    const urgColor=daysLeft!=null?daysLeft<0?'#A32D2D':daysLeft<=3?'#EF9F27':'#185FA5':'';
    const dateTag=hu.planDate?`<div style="font-size:9px;color:${urgColor};line-height:1.1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${hu.planDate.slice(5)}</div>`:'';
