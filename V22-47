function restoreRow(compId){
  const c=S.completed.find(x=>x.compId===compId);
  if(!c)return;
  if(!confirm('確定將此項目移回追蹤總表？'))return;
  const {compId:_c,completedAt:_a,...row}=c;
  S.rows.push(row);
  S.completed=S.completed.filter(x=>x.compId!==compId);
  save();renderAll();toast('已移回追蹤總表');
}
function delCompleted(compId){
  if(!confirm('確定永久刪除此完成記錄？'))return;
  S.completed=S.completed.filter(x=>x.compId!==compId);
  save();renderDone();toast('已刪除','🗑');
}

