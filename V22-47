function buildUnitDefectTable(unitKey){
  // unitKey may be like "地A1-27" — match against S.rows by unit field (strip 地/業 prefix)
  const displayName=unitDisplayName(unitKey);
  const rows=S.rows.filter(r=>r.unit===displayName||r.unit===unitKey);
  if(!rows.length)return`<div style="font-size:11px;color:var(--text3);padding:4px 0">此戶目前無缺失項目記錄</div>`;
  const thead=`<tr style="background:#ECEAE6"><th style="padding:4px 6px;font-size:10px;font-weight:600">廠商</th><th style="padding:4px 6px;font-size:10px;font-weight:600">缺失內容</th><th style="padding:4px 6px;font-size:10px;font-weight:600">預計完成</th><th style="padding:4px 6px;font-size:10px;font-weight:600">狀態</th></tr>`;
  const tbody=rows.map(r=>{
    const st=getStatus(r);
    const stLabel={done:'已完成',ongoing:'進行中',overdue:'逾期',pending:'未開始'}[st]||'';
    const stColor={done:var_green,ongoing:var_blue,overdue:var_red,pending:'var(--text3)'}[st]||'';
    return`<tr style="border-bottom:1px solid var(--border2)"><td style="padding:3px 6px;font-size:10px">${esc(r.vendor)}</td><td style="padding:3px 6px;font-size:10px;max-width:180px;word-break:break-all">${esc(r.issue)}</td><td style="padding:3px 6px;font-size:10px;white-space:nowrap">${r.planDone||'—'}</td><td style="padding:3px 6px;font-size:10px;color:${stColor}">${stLabel}</td></tr>`;
  }).join('');
  return`<div style="overflow-x:auto;border:1px solid var(--border);border-radius:var(--rs)"><table style="width:100%;border-collapse:collapse"><thead>${thead}</thead><tbody>${tbody}</tbody></table></div>`;
}
const var_green='var(--green)',var_blue='var(--blue)',var_red='var(--red)';
function toggleUnitDefects(key){
  const el=document.getElementById('defects-'+key);
  if(!el)return;
  el.style.display=el.style.display==='none'?'block':'none';
}
function printUnitDefects(unitKey){
  const displayName=unitDisplayName(unitKey);
  const rows=S.rows.filter(r=>r.unit===displayName||r.unit===unitKey);
  const hu=(S.handoverUnits&&S.handoverUnits[unitKey])||{};
  const cl=(S.clientData&&S.clientData[unitKey])||{};
  const grade=hoGrade(hoUnitPct(displayName)||hoUnitPct(unitKey));
  const pct=hoUnitPct(displayName)||hoUnitPct(unitKey);
  const info=`<div style="margin-bottom:10px;font-size:11px;color:#555">
    <span>戶別：<strong>${esc(unitKey)}</strong></span>
    ${cl.name?`<span style="margin-left:12px">客戶：${esc(cl.name)}</span>`:''}
    ${cl.tel?`<span style="margin-left:12px">電話：${esc(cl.tel)}</span>`:''}
    <span style="margin-left:12px">完成度：<strong style="color:${grade.color}">${pct??'—'}%</strong></span>
    ${hu.planDate?`<span style="margin-left:12px">預定驗收：${hu.planDate}</span>`:''}
  </div>`;
  const thead=`<tr><th>廠商</th><th>缺失內容</th><th>備註</th><th>預計進場</th><th>預計完成</th><th>實際完成</th><th>狀態</th></tr>`;
  const tbody=rows.map(r=>{const st=getStatus(r);const stLabel={done:'已完成',ongoing:'進行中',overdue:'逾期',pending:'未開始'}[st]||'';return`<tr class="r-${st}"><td>${esc(r.vendor)}</td><td>${esc(r.issue)}</td><td>${esc(r.note)}</td><td>${fmtMD(r.planIn)}</td><td>${fmtMD(r.planDone)}</td><td>${r.actualDone?fmtMD(r.actualDone):'—'}</td><td>${stLabel}</td></tr>`;}).join('');
  const empty=!rows.length?'<p style="color:#888;font-size:11px">此戶目前無缺失項目記錄</p>':'';
  printSection(`缺失清單 — ${unitKey}`,info+(rows.length?`<table><thead>${thead}</thead><tbody>${tbody}</tbody></table>`:empty));
