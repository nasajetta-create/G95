        const raw=rawData[col];const key=raw?raw[fl]:null;
        return makeGridCell(key,fl,col,blockId,'');
      }).join('');
      const expandKey=cols.map(col=>{const raw=rawData[col];return raw?raw[fl]:null;}).find(k=>k&&_expandedUnit===k);
      const expandDiv=expandKey?`<div style="grid-column:1/-1;margin:2px 0">${buildExpandedUnit(expandKey)}</div>`:'';
