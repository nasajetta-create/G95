      }).join('');
      const staticPark=G95_PARKING[key]||[];
      const allPark=[...new Set([...staticPark,...(cl.parkings||[])])];
      const parkChips=allPark.length?allPark.map(p=>`<span style="font-size:10px;padding:1px 6px;background:#E6F1FB;color:#0C447C;border-radius:20px;display:inline-flex;align-items:center;gap:3px">🚗 ${esc(p)} <input type="checkbox" title="已驗收" ${(hu.parkChecked||{})[p]?'checked':''} onchange="setHuParkCheck('${esc(key)}','${esc(p)}',this.checked)" style="accent-color:var(--green);cursor:pointer"></span>`).join(''):'';
      expandHtml=`<div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--border2)">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:7px">
          <div><span style="font-size:10px;color:var(--text2)">客戶姓名</span><br><input value="${esc(cl.name||'')}" placeholder="姓名" onchange="setCl('${esc(key)}','name',this.value)" onclick="event.stopPropagation()" style="width:100%;font-size:11px;padding:3px 5px;border:1px solid var(--border);border-radius:var(--rs);font-family:var(--font);margin-top:2px"></div>
          <div><span style="font-size:10px;color:var(--text2)">電話</span><br><input value="${esc(cl.tel||'')}" placeholder="電話" onchange="setCl('${esc(key)}','tel',this.value)" onclick="event.stopPropagation()" style="width:100%;font-size:11px;padding:3px 5px;border:1px solid var(--border);border-radius:var(--rs);font-family:var(--font);margin-top:2px"></div>
        </div>
        ${parkChips?`<div style="margin-bottom:7px;display:flex;flex-wrap:wrap;gap:4px">${parkChips}</div>`:''}
        <div style="display:flex;align-items:flex-end;gap:6px;flex-wrap:wrap">
          <div style="display:flex;flex-direction:column;gap:2px">
            <span style="font-size:10px;color:var(--text2)">預定驗收</span>
            <input type="date" value="${esc(hu.planDate||'')}" onchange="setHuField('${esc(key)}','planDate',this.value)" onclick="event.stopPropagation()" style="font-size:10px;padding:2px 4px;border:1px solid var(--border);border-radius:var(--rs);font-family:var(--font)">
          </div>
          <div style="display:flex;flex-direction:column;gap:2px">
            <span style="font-size:10px;color:var(--text2)">驗收時段</span>
            <select onchange="setHuField('${esc(key)}','slot',this.value)" onclick="event.stopPropagation()" style="font-size:10px;padding:2px 5px;border:1px solid var(--border);border-radius:var(--rs);font-family:var(--font)">
              <option value="" ${!hu.slot?'selected':''}>— 未設定 —</option>
              <option value="09:00–10:20" ${hu.slot==='09:00–10:20'?'selected':''}>09:00–10:20</option>
              <option value="10:30–11:50" ${hu.slot==='10:30–11:50'?'selected':''}>10:30–11:50</option>
              <option value="14:00–15:20" ${hu.slot==='14:00–15:20'?'selected':''}>14:00–15:20</option>
              <option value="15:30–16:50" ${hu.slot==='15:30–16:50'?'selected':''}>15:30–16:50</option>
            </select>
          </div>
          ${inspCols}
          <button class="btn btn-sm" onclick="event.stopPropagation();addHuInspH2('${esc(key)}')" style="padding:2px 6px;align-self:flex-end;font-size:10px">＋</button>
          <button class="btn btn-sm btn-g" onclick="event.stopPropagation();toggleDeliveredH('${esc(key)}')" style="align-self:flex-end;padding:2px 8px;font-size:10px">${hu.delivered?'取消交屋':'🏠 已交屋'}</button>
        </div>
        <div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--border2)">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
            <span style="font-size:10px;font-weight:600">📋 缺失清單</span>
            ${(()=>{const dn=unitDisplayName(key);const dr=S.rows.filter(r=>r.unit===dn||r.unit===key);const dt=dr.length;const dp=dr.filter(r=>!r.actualDone).length;return dt?`<span style="padding:1px 7px;border-radius:20px;font-size:10px;background:${dp>0?'#FCEBEB':'#EAF3DE'};color:${dp>0?'#791F1F':'#3B6D11'};font-weight:600">缺失 ${dp}/${dt}</span>`:''})()}
            <button class="btn btn-sm btn-pdf no-print" onclick="event.stopPropagation();printUnitDefects('${esc(key)}')" style="margin-left:auto;font-size:10px">🖨 PDF</button>
