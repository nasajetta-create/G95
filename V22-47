      expandHtml=`<div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--border2)"><div style="display:flex;align-items:flex-end;gap:6px;flex-wrap:wrap"><div style="display:flex;flex-direction:column;gap:2px"><span style="font-size:10px;color:var(--text2)">預定驗收</span><input type="date" value="${esc(hu.planDate||'')}" onchange="setHuField('${esc(u)}','planDate',this.value)" style="font-size:11px;padding:3px 5px;border:1px solid var(--border);border-radius:var(--rs);font-family:var(--font)"></div>${inspCols}<button class="btn btn-sm" onclick="event.stopPropagation();addHuInspH2('${esc(u)}')" style="padding:2px 6px;align-self:flex-end;font-size:10px">＋</button><button class="btn btn-sm btn-g" onclick="event.stopPropagation();toggleDeliveredH('${esc(u)}')" style="align-self:flex-end;padding:2px 8px;font-size:10px">${hu.delivered?'取消':'🏠 已交屋'}</button></div></div>`;
    }
