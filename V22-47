let _hcalOffset=0; // 週偏移，0=本週
const HCAL_SLOTS=['09:00–10:20','10:30–11:50','14:00–15:20','15:30–16:50'];

function renderHCal(){
  if(!S.handoverUnits)S.handoverUnits={};
  const today=new Date();today.setHours(0,0,0,0);
  const dow=today.getDay()===0?6:today.getDay()-1; // 週一=0
  const isoDate=d=>`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;

  // 若 _hcalOffset===0 且本週無活動，自動跳到最近一次有活動的週次
  const baseMonday=new Date(today);baseMonday.setDate(today.getDate()-dow);
  function weekHasActivity(mondayDate){
    for(let i=0;i<7;i++){
      const d=new Date(mondayDate);d.setDate(mondayDate.getDate()+i);
      const ds=isoDate(d);
      if(Object.values(S.handoverUnits).some(hu=>hu.planDate===ds))return true;
    }
    return false;
  }
  if(_hcalOffset===0&&!weekHasActivity(baseMonday)){
    // 找最近有活動的週（先找未來，再找過去）
    let found=false;
    for(let delta=1;delta<=52;delta++){
      const futMon=new Date(baseMonday);futMon.setDate(baseMonday.getDate()+delta*7);
      if(weekHasActivity(futMon)){_hcalOffset=delta;found=true;break;}
      const pastMon=new Date(baseMonday);pastMon.setDate(baseMonday.getDate()-delta*7);
      if(weekHasActivity(pastMon)){_hcalOffset=-delta;found=true;break;}
    }
  }

  const weekStart=new Date(baseMonday);weekStart.setDate(baseMonday.getDate()+(_hcalOffset*7));
  const week2Start=new Date(weekStart);week2Start.setDate(weekStart.getDate()+7);
  const week1Days=Array.from({length:7},(_,i)=>{const d=new Date(weekStart);d.setDate(weekStart.getDate()+i);return d;});
  const week2Days=Array.from({length:7},(_,i)=>{const d=new Date(week2Start);d.setDate(week2Start.getDate()+i);return d;});
  const fmtDate=d=>`${d.getMonth()+1}/${d.getDate()}`;
  const fmtDay=d=>['日','一','二','三','四','五','六'][d.getDay()];

  function getUnitsForDateSlot(dateStr,slot){
    const result=[];
    Object.entries(S.handoverUnits).forEach(([key,hu])=>{
      if(hu.planDate===dateStr&&(!slot||hu.slot===slot)){
        const pct=hoUnitPct(unitDisplayName(key))||hoUnitPct(key);
        result.push({key,pct,delivered:hu.delivered});
      }
    });
    return result;
  }

  function buildWeekTable(days,title){
    const isWeekend=d=>d.getDay()===0||d.getDay()===6;
    const todayStr=isoDate(today);

    const dateHdrs=days.map(d=>{
      const ds=isoDate(d);const isToday=ds===todayStr;
      const diff=Math.ceil((d-today)/86400000);
      const diffLabel=isToday?'今天':diff>0?`${diff}天後`:`${Math.abs(diff)}天前`;
      const bg=isToday?'#F0EEFF':isWeekend(d)?'#F5F3EE':'var(--surface)';
      const color=isToday?'var(--purple)':diff<0?'var(--text3)':diff<=3?'var(--red)':'var(--text2)';
      return`<th style="padding:5px 4px;text-align:center;border:1px solid var(--border);font-size:12px;min-width:100px;background:${bg}">
        ${fmtDate(d)}&nbsp;<span style="font-size:10px;color:var(--text3)">週${fmtDay(d)}</span><br>
        <span style="font-size:10px;color:${color}">${diffLabel}</span>
      </th>`;
    }).join('');

    const slotRows=HCAL_SLOTS.map(slot=>{
      const cells=days.map(d=>{
        const dateStr=isoDate(d);
        const units=getUnitsForDateSlot(dateStr,slot);
        if(!units.length)return`<td style="border:1px solid var(--border);padding:4px;vertical-align:top;height:50px"></td>`;
        const chips=units.map(({key,pct,delivered})=>{
          const color=delivered?'#3B6D11':pct===100?'#3B6D11':pct>=80?'#854F0B':'#A32D2D';
          return`<div style="font-size:10px;padding:2px 6px;margin-bottom:2px;border-radius:3px;background:#F0EEFF;color:${color};white-space:nowrap">${esc(key)}<span style="opacity:.6;font-size:9px"> ${pct??'—'}%</span></div>`;
        }).join('');
        return`<td style="border:1px solid var(--border);padding:4px;vertical-align:top;background:#FAF8FF"><div style="font-size:10px;font-weight:600;color:var(--purple);margin-bottom:3px">${units.length}戶</div>${chips}</td>`;
      }).join('');
      return`<tr><td style="padding:6px 10px;font-size:11px;border:1px solid var(--border);white-space:nowrap;font-weight:500;background:var(--surface)">${slot}</td>${cells}</tr>`;
    }).join('');

    // 統計列
    const statRow=`<tr style="background:var(--surface)">
      <td style="padding:4px 10px;font-size:11px;border:1px solid var(--border);font-weight:600">預定驗收 戶數</td>
      ${days.map(d=>{
        const ds=isoDate(d);
        const n=Object.values(S.handoverUnits).filter(hu=>hu.planDate===ds&&hu.slot&&HCAL_SLOTS.includes(hu.slot)).length;
        return`<td style="text-align:center;padding:4px;font-size:12px;border:1px solid var(--border);${n?'font-weight:600;color:var(--purple)':''}">${n||''}</td>`;
      }).join('')}
    </tr>`;

    return`<div style="margin-bottom:14px">
      <div style="font-size:12px;font-weight:600;color:var(--text2);padding:4px 8px;background:var(--surface);border-radius:var(--rs);margin-bottom:5px">${title}</div>
      <div style="overflow-x:auto">
        <table style="border-collapse:collapse;width:100%;min-width:700px">
          <thead><tr>
            <th style="padding:6px 10px;border:1px solid var(--border);background:var(--surface);white-space:nowrap;min-width:90px;font-size:11px">時段 / 日期</th>
            ${dateHdrs}
          </tr></thead>
          <tbody>${slotRows}${statRow}</tbody>
        </table>
      </div>
    </div>`;
  }

  const w1Title=`第 ${_hcalOffset*2+1} 週（${fmtDate(week1Days[0])} – ${fmtDate(week1Days[6])}）`;
  const w2Title=`第 ${_hcalOffset*2+2} 週（${fmtDate(week2Days[0])} – ${fmtDate(week2Days[6])}）`;

  document.getElementById('pane-hcal').innerHTML=`
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap">
      <span style="font-size:13px;font-weight:700">📆 交屋行事曆</span>
      <button class="btn btn-sm" onclick="_hcalOffset--;renderHCal()">◀ 上兩週</button>
      <button class="btn btn-sm" onclick="_hcalOffset=0;renderHCal()">本週</button>
      <button class="btn btn-sm" onclick="_hcalOffset++;renderHCal()">下兩週 ▶</button>
      <span style="font-size:12px;color:var(--text2)">${fmtDate(week1Days[0])} – ${fmtDate(week2Days[6])}</span>
      <button class="btn btn-pdf btn-sm no-print" onclick="printHCal()" style="margin-left:auto">🖨 PDF</button>
    </div>
    ${buildWeekTable(week1Days,w1Title)}
    ${buildWeekTable(week2Days,w2Title)}
    <div style="padding:7px 10px;background:var(--surface);border-radius:var(--rs);font-size:11px;color:var(--text3)">
      💡 驗收時段在「客戶交屋狀態表」中展開各戶卡片設定。紫色底色格代表有安排戶別。
    </div>`;
}
function printHCal(){
  const el=document.getElementById('pane-hcal');
  const tables=el.querySelectorAll('table');
  const html=Array.from(tables).map(t=>t.outerHTML).join('<br>');
  printSection('交屋行事曆',html);
}

function renderPubArea(){
  if(!S.handoverUnits)S.handoverUnits={};
  if(!S.publicAreaList)S.publicAreaList={A:[],B:[]};
  const today=new Date();today.setHours(0,0,0,0);

  function classifyRow(r){
    const unit=String(r.unit||'');const floor=String(r.floor||'').toUpperCase();
    const zoneLabel=S.zones.find(z=>z.id===r.zone);const zoneName=zoneLabel?zoneLabel.label:'';
    if(/店鋪|shop/i.test(unit)||/地A\d+$|業A\d+$|地C\d/i.test(unit))return null;
    const isPublicZone=zoneName.includes('公設');
    const isStairA=/甲梯|乙梯|A棟梯廳|A梯廳/.test(unit);
    const isStairB=/丙梯|丁梯|B棟梯廳|B梯廳/.test(unit);
    const isStairCommon=/梯廳|樓梯間/.test(unit)&&!isStairA&&!isStairB;
    const isBasementFloor=/^B[1-5]F?$|^B[1-5]$|車道|機車道/.test(floor)||/車道|機車道/.test(unit);
    if(!isPublicZone&&!isStairA&&!isStairB&&!isStairCommon&&!isBasementFloor)return null;
    if(isBasementFloor)return'basement';
    if(isStairA||(isPublicZone&&/A棟|A梯/.test(zoneName)))return'pubA';
    if(isStairB||(isPublicZone&&/B棟|B梯/.test(zoneName)))return'pubB';
    if(isPublicZone)return'pubA';
    return null;
  }

  const pubAUnits=new Set(),pubBUnits=new Set(),basementUnitsSet=new Set();
  S.rows.forEach(r=>{if(!r.unit)return;const cls=classifyRow(r);if(cls==='pubA')pubAUnits.add(r.unit);else if(cls==='pubB')pubBUnits.add(r.unit);else if(cls==='basement')basementUnitsSet.add(r.unit);});

