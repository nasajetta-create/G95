      </div>`;
    }
    const chk=_hstatsSelected.has(key);
    // 驗收日期行（直接顯示，不需點開）
    const inspsAll=hu.inspections||[];
    // 車位
    const staticPark2=G95_PARKING[key]||[];
    const allPark3=[...new Set([...staticPark2,...(cl.parkings||[])])];
    const parkBadge=allPark3.length?`<span style="font-size:10px;color:#0C447C;background:#E6F1FB;border-radius:20px;padding:1px 6px">🚗 ${allPark3.join('、')}</span>`:'';
    let dateRowHtml='';
    if(hu.planDate||inspsAll.length){
      const planTag=hu.planDate?`<span style="display:inline-flex;align-items:center;gap:3px;font-size:10px;padding:1px 7px;background:#EBF4FF;color:#185FA5;border-radius:20px">📅 預定 ${hu.planDate}${daysLeft!=null&&!hu.delivered?`（${daysLeft>=0?daysLeft+'天後':'逾期'+Math.abs(daysLeft)+'天'}）`:''}</span>`:'';
      const inspTags=inspsAll.map(ins=>`<span style="display:inline-flex;align-items:center;gap:3px;font-size:10px;padding:1px 7px;background:${ins.date?'#EAF3DE':'var(--surface)'};color:${ins.date?'#3B6D11':'var(--text3)'};border-radius:20px">${esc(ins.label)} ${ins.date?ins.date:'—'}</span>`).join('');
      const delivTag=hu.delivered?`<span style="font-size:10px;padding:1px 7px;background:#EAF3DE;color:#3B6D11;border-radius:20px">🏠 已交屋</span>`:'';
      const slotTag=hu.slot?`<span style="display:inline-flex;align-items:center;gap:3px;font-size:10px;padding:1px 7px;background:#F0EEFF;color:#3C3489;border-radius:20px">🕐 ${hu.slot}</span>`:'';
      dateRowHtml=`<div style="margin-top:5px;display:flex;flex-wrap:wrap;gap:4px">${planTag}${slotTag}${inspTags}${delivTag}</div>`;
    }
    return`<div style="${typeBg}${cardBorder}border-radius:var(--r);padding:8px 10px;margin-bottom:5px;cursor:default" onclick="if(event.target.closest('input,button,select'))return;toggleHUnit('${esc(key)}')">
      <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
        <input type="checkbox" ${chk?'checked':''} onclick="event.stopPropagation()" onchange="toggleHStatsSel('${esc(key)}',this.checked)">
        <span style="font-size:12px;font-weight:600">${esc(displayName)}</span>
        <span style="font-size:11px;color:var(--text3)">${floor}F</span>
        ${isOwner?`<span style="font-size:10px;padding:1px 6px;border-radius:20px;background:#EEEDFE;color:#3C3489">地主</span>`:isBiz?`<span style="font-size:10px;padding:1px 6px;border-radius:20px;background:#E1F5EE;color:#085041">業主</span>`:''}
        ${cl.name?`<span style="font-size:10px;color:var(--text2)">${esc(cl.name)}</span>`:''}
        <div style="flex:1;display:flex;align-items:center;gap:6px;justify-content:flex-end">
