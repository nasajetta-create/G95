function confirmClientEdit(key){
  if(!S.clientData)S.clientData={};
  if(!S.clientData[key])S.clientData[key]={name:'',tel:'',type:'自購戶',parkings:[],note:''};
  // 補抓 DOM 中最新值（確保即使 oninput 沒觸發也能讀到）
  const allCards=document.querySelectorAll('[data-cl-key]');
  let card=null;
  allCards.forEach(el=>{if(el.getAttribute('data-cl-key')===key)card=el;});
  if(card){
    const n=card.querySelector('.cl-inp-name');if(n)clBufSet(key,'name',n.value);
    const t=card.querySelector('.cl-inp-tel');if(t)clBufSet(key,'tel',t.value);
    const tp=card.querySelector('.cl-inp-type');if(tp)clBufSet(key,'type',tp.value);
    const nt=card.querySelector('.cl-inp-note');if(nt)clBufSet(key,'note',nt.value);
  }
  const buf=_clEditBuf[key]||{};
  if(buf.name!=null)S.clientData[key].name=buf.name;
  if(buf.tel!=null)S.clientData[key].tel=buf.tel;
  if(buf.type)S.clientData[key].type=buf.type;
  if(buf.note!=null)S.clientData[key].note=buf.note;
  delete _clEditBuf[key];
  save();
  toast(`${key} 已儲存 ✅`);
  _clientExpanded=null;
  renderClients();
}

