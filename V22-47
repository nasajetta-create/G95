// Undo buffer for batch changes
let _bchUndoStack=[];
function saveBchUndo(keys,fields){
  // Save snapshot of affected keys before change
  const snap={};
  keys.forEach(key=>{
    snap[key]={
      handoverUnit:S.handoverUnits[key]?{...S.handoverUnits[key]}:null,
      clientData:S.clientData[key]?{...S.clientData[key]}:null
    };
  });
  _bchUndoStack.push(snap);
  if(_bchUndoStack.length>10)_bchUndoStack.shift();
}
function undoBatchHStats(){
  if(!_bchUndoStack.length){toast('沒有可恢復的操作','⚠️');return;}
  const snap=_bchUndoStack.pop();
  Object.entries(snap).forEach(([key,data])=>{
    if(data.handoverUnit===null)delete S.handoverUnits[key];
    else{if(!S.handoverUnits)S.handoverUnits={};S.handoverUnits[key]=data.handoverUnit;}
    if(data.clientData===null)delete S.clientData[key];
    else{if(!S.clientData)S.clientData={};S.clientData[key]=data.clientData;}
  });
  save();toast(`已恢復上一個批次動作（${Object.keys(snap).length} 戶）`,'↩️');
  renderHStats();
}
function resetBatchHStats(){
