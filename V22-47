// ── 防抖重繪計時器 ───────────────────────────────────────────────────────
let _renderTimer=null;
function scheduleRender(){
  clearTimeout(_renderTimer);
  _renderTimer=setTimeout(()=>{_renderTimer=null;renderAll();},80);
}

function upd(id,f,v,skipCheck){
  const r=S.rows.find(x=>x.id===id);if(!r)return;
  if(!skipCheck){
    if(f==='planDone'&&v&&r.planIn&&v<r.planIn){toast('完成日期不可早於進場日期','⚠️');renderAll();return;}
    if(f==='actualDone'&&v&&r.actualIn&&v<r.actualIn){toast('實際完成日期不可早於實際進場日期','⚠️');renderAll();return;}
  }
  const old=r[f];r[f]=v;
  if(f==='planIn'&&v&&!r.planDone){r.planDone=v;}
  if(f==='actualDone'&&v&&!r.actualIn)r.actualIn=v;
  if(String(old)!==String(r[f])){
    const L={manager:'管理人',unit:'戶別',floor:'樓層',vendor:'廠商',issue:'缺失內容',note:'備註',planIn:'預計進場',planDone:'預計完成',actualIn:'實際進場',actualDone:'實際完成',zone:'區域'};
    const isLayout=['vendor','zone','manager'].includes(f);
    save();
    if(isLayout){renderAll();}else{toast(`已更新 #${id} ${L[f]||f}：${v||'(清空)'}`);}
  }
}
