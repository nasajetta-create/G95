function _buildBatchBarHTML(){
  const blk=window._bchBlock||new Set();
  const selFl=window._bchFloors||new Set();
  const selCols=window._bchCols||new Set();
  const hasA=blk.size===0||blk.has('A');
  const hasB=blk.size===0||blk.has('B');
  const hasShop=blk.size===0||blk.has('shop');

  // 方塊按鈕樣式：無圓角、無間隙，選中紫色，未選灰色
  const btnStyle=(active)=>`font-size:11px;padding:3px 9px;border-radius:3px;border:1px solid ${active?'var(--purple)':'var(--border)'};border-right:none;background:${active?'#F0EEFF':'var(--card)'};color:${active?'var(--purple)':'var(--text2)'};cursor:pointer;white-space:nowrap`;
  const btnLast=(active)=>`font-size:11px;padding:3px 9px;border-radius:3px;border:1px solid ${active?'var(--purple)':'var(--border)'};background:${active?'#F0EEFF':'var(--card)'};color:${active?'var(--purple)':'var(--text2)'};cursor:pointer;white-space:nowrap`;

  // 棟別按鈕
  const blockItems=['all','A','B','shop'];
  const blockBtns=blockItems.map((b,i)=>{
    const active=b==='all'?blk.size===0:blk.has(b);
    const label={all:'全部',A:'A棟',B:'B棟',shop:'店鋪'}[b];
    const isLast=i===blockItems.length-1;
    return`<button onclick="bchToggleBlock('${b}')" style="${isLast?btnLast(active):btnStyle(active)}">${label}</button>`;
  }).join('');

  // 樓層按鈕（依棟別）
  let floors=[];
  if(hasA||hasB)floors=[...G95_FLOORS];
  if(hasShop){if(!floors.includes(1))floors.push(1);if(!floors.includes(2))floors.push(2);}
  floors=floors.sort((a,b2)=>b2-a);
  const floorItems=floors.length?['all',...floors.map(String)]:[];
  const floorBtns=floorItems.map((fl,i)=>{
    const active=fl==='all'?selFl.size===0:selFl.has(fl);
    const label=fl==='all'?'全部':`${fl}F`;
    const isLast=i===floorItems.length-1;
    return`<button onclick="bchToggleFloor('${fl}')" style="${isLast?btnLast(active):btnStyle(active)}">${label}</button>`;
  }).join('');

  // 戶別按鈕（依棟別+樓層）
  const colSet=new Set();
  function addColsForBlock(rawData,cols){
    cols.forEach(col=>{
      const colObj=rawData[col];if(!colObj)return;
      const fls=selFl.size>0?[...selFl].map(Number):G95_FLOORS;
      if(fls.some(fl=>colObj[fl]!=null))colSet.add(col);
    });
  }
  if(hasA)addColsForBlock(G95_RAW_A,G95_A_COLS);
  if(hasB)addColsForBlock(G95_RAW_B,G95_B_COLS);
  if(hasShop)['A1','A2','A3','A5','A6','A7','A8','A9','A10','A11','A12','A15','A16','A17','A18','A19','A20','A21','A22','A23','A25','A26','A27','A28','A29','A30','C1','C2'].forEach(c=>colSet.add('shop:'+c));
  const cols=[...colSet].sort((a,b2)=>a.localeCompare(b2,'zh-TW',{numeric:true}));
  const colItems=cols.length?['all',...cols]:[];
  const colBtns=colItems.map((col,i)=>{
    const active=col==='all'?selCols.size===0:selCols.has(col);
    const label=col==='all'?'全部':col.replace(/^shop:/,'');
    const isLast=i===colItems.length-1;
    return`<button onclick="bchToggleCol('${col}')" style="${isLast?btnLast(active):btnStyle(active)}">${label}</button>`;
  }).join('');
  return`
    <div style="display:flex;align-items:center;gap:6px;flex-wrap:nowrap;overflow-x:auto;padding-bottom:2px;margin-bottom:4px">
      <span style="font-size:11px;color:var(--text2);font-weight:500;flex-shrink:0">棟別：</span>
      <div style="display:flex;flex-wrap:nowrap;gap:0">${blockBtns}</div>
    </div>
    ${floors.length?`<div style="display:flex;align-items:center;gap:6px;flex-wrap:nowrap;overflow-x:auto;padding-bottom:2px;margin-bottom:4px">
      <span style="font-size:11px;color:var(--text2);font-weight:500;flex-shrink:0">樓層：</span>
      <div style="display:flex;flex-wrap:nowrap;gap:0;overflow-x:auto">${floorBtns}</div>
    </div>`:''}
    ${cols.length?`<div style="display:flex;align-items:center;gap:6px;flex-wrap:nowrap;overflow-x:auto;padding-bottom:2px">
      <span style="font-size:11px;color:var(--text2);font-weight:500;flex-shrink:0">戶別：</span>
      <div style="display:flex;flex-wrap:nowrap;gap:0;overflow-x:auto">${colBtns}</div>
    </div>`:''}`;
}
function confirmBatchHStats(){
  if(!S.handoverUnits)S.handoverUnits={};
  if(!S.clientData)S.clientData={};
  const bchDate=window._bchDate||'';
  const bchTs=window._bchTs||'';
  // 讀取 select 的最新值（每次 render 後 select 已重設）
  const bchTypeSel=document.getElementById('bch-type-sel');
  const bchType=bchTypeSel?bchTypeSel.value:(window._bchTypeVal||'');
  if(bchTypeSel)window._bchTypeVal=bchTypeSel.value; // 同步
  if(!bchDate&&!bchTs&&!bchType){toast('請先設定要批次變更的欄位（日期、時段或類別）','⚠️');return;}
  const bchBlock=window._bchBlock||new Set();
  const bchFloors=window._bchFloors||new Set();
  const bchCols=window._bchCols||new Set();
  const keys=[];
  function collectKeys(rawData,cols){
    G95_FLOORS.forEach(fl=>{
      if(bchFloors.size>0&&!bchFloors.has(String(fl)))return;
      cols.forEach(col=>{
        if(bchCols.size>0&&!bchCols.has(col))return;
        const raw=rawData[col];const key=raw?raw[fl]:null;
        if(key)keys.push(key);
      });
    });
  }
  if(bchBlock.size===0||bchBlock.has('A'))collectKeys(G95_RAW_A,G95_A_COLS);
  if(bchBlock.size===0||bchBlock.has('B'))collectKeys(G95_RAW_B,G95_B_COLS);
  if(bchBlock.size===0||bchBlock.has('shop')){
    const shopAllKeys=['地A1-1','A2-1','A3-1','業A5-1','地A6-1','地A7-1','地A8-1','地A9-1','地A10-1','地A11-1','地A12-1','地A15-1','地A16-1','地A17-1','地A18-1','地A19-1','地A20-1','地A21-1','地A22-1','地A23-1','地A25-1','地A26-1','地A27-1','業A28-1','地A29-1','業A30-1','業C2-1','地C1-2'];
    shopAllKeys.forEach(key=>{
      const fl=key==='地C1-2'?2:1;
      if(bchFloors.size>0&&!bchFloors.has(String(fl)))return;
      // 店鋪戶別：bchCols 中用 shop: 前綴，全部不選代表全選
      if(bchCols.size>0){
        const colMatch=key.match(/([A-C]\d+)/);
        const col=colMatch?('shop:'+colMatch[1]):'';
        if(col&&!bchCols.has(col))return;
      }
      keys.push(key);
    });
  }
  if(keys.length===0){toast('沒有符合條件的戶別','⚠️');return;}
  // Save undo snapshot before modifying
  saveBchUndo(keys);
  keys.forEach(key=>{
    if(!S.handoverUnits[key])S.handoverUnits[key]={};
    if(bchDate)S.handoverUnits[key].planDate=bchDate;
    if(bchTs)S.handoverUnits[key].slot=bchTs;
    if(bchType){
      if(!S.clientData[key])S.clientData[key]={name:'',tel:'',type:'自購戶',parkings:[],note:''};
      S.clientData[key].type=bchType;
    }
  });
  save();
  toast(`已批次更新 ${keys.length} 戶 ✅`);
  // 保留日期、時段、類別，只清除棟別/樓層/戶別選取
  window._bchBlock=new Set();
  window._bchFloors=new Set();
  window._bchCols=new Set();
  renderHStats();
}


