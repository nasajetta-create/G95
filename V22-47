    {id:'PB-R1',label:'B棟 R1F 頂樓',floor:'R1F',zone:'B'},
  ]};       // {unitKey:{name,tel,type,parkings:[],note}}
  d.rows.forEach(r=>{if(!('manager' in r))r.manager='';});
  return d;
}

// ── helpers ───────────────────────────────────────────────────────────────
const TODAY=new Date();TODAY.setHours(0,0,0,0);
const todayISO=()=>TODAY.toISOString().slice(0,10);
const pd=s=>{if(!s)return null;const d=new Date(s);d.setHours(0,0,0,0);return isNaN(d)?null:d};
const du=s=>{const d=pd(s);if(!d)return null;return Math.ceil((d-TODAY)/86400000)};
const fmtMD=s=>{const d=pd(s);if(!d)return'';return`${d.getMonth()+1}/${d.getDate()}(${DOW[d.getDay()]})`};
const esc=s=>String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
const dotC=st=>({done:'#2E6B26',ongoing:'#185FA5',overdue:'#A32D2D',pending:'#B4B2A9'})[st]||'#B4B2A9';
function getStatus(r){
  if(r.actualDone)return'done';
  const d=du(r.planDone);
  if(d!==null&&d<0)return'overdue';
  if(r.actualIn)return'ongoing';
  return'pending';
}
function dot(st){return`<span class="dot" style="background:${dotC(st)}"></span>`}
function badge(r){
  const st=getStatus(r),d=du(r.planDone);
  if(st==='done')return`<span class="badge bdone">✅完成</span>`;
  if(st==='overdue')return`<span class="badge bover">🔴逾期</span>`;
  if(d!==null&&d<=3)return`<span class="badge b3">🟠${d}天</span>`;
  if(d!==null&&d<=7)return`<span class="badge b7">🔵${d}天</span>`;
  return`<span style="color:var(--text3);font-size:10px">—</span>`;
}
function rClass(r){
  const st=getStatus(r),d=du(r.planDone);
  if(st==='done')return'r-done';if(st==='overdue')return'r-over';
  if(d!==null&&d<=3)return'r-w3';if(d!==null&&d<=7)return'r-w7';return'';
}
function vOpts(sel){return S.vendors.map(v=>`<option value="${esc(v)}"${v===sel?' selected':''}>${esc(v)}</option>`).join('')}
function zOpts(sel){return S.zones.map(z=>`<option value="${z.id}"${z.id===sel?' selected':''}>${esc(z.label)}</option>`).join('')}
function mOpts(sel){return['', ...S.managers].map(m=>`<option value="${esc(m)}"${m===sel?' selected':''}>${m?esc(m):'— 無 —'}</option>`).join('')}
function zLabel(id){return(S.zones.find(z=>z.id===id)||{label:id}).label}
function zColor(id){return(S.zones.find(z=>z.id===id)||{color:'#888'}).color}
function vColor(v){const i=S.vendors.indexOf(v);return V_COLORS[i>=0?i%V_COLORS.length:7]}
function uniqueUnits(){return[...new Set(S.rows.map(r=>r.unit).filter(Boolean))].sort()}
function dowStr(iso){const d=pd(iso);if(!d)return'';return`(${DOW[d.getDay()]})`}

// ── toast ─────────────────────────────────────────────────────────────────
function toast(msg,icon='✏️'){
  const w=document.getElementById('toast-wrap');
  const d=document.createElement('div');d.className='toast';
  d.innerHTML=`<span>${icon}</span><span>${esc(msg)}</span>`;
  w.appendChild(d);
  setTimeout(()=>{d.style.transition='opacity .3s';d.style.opacity='0';setTimeout(()=>d.remove(),300)},3200);
}

// ── modal for list item editing ───────────────────────────────────────────
function openModal(title,currentName,onSave,onDelete){
  modalCtx={onSave,onDelete};
  document.getElementById('modalTitle').textContent=title;
  document.getElementById('modalInput').value=currentName;
  document.getElementById('modalDel').style.display=onDelete?'':'none';
  document.getElementById('modalBg').classList.add('show');
  setTimeout(()=>document.getElementById('modalInput').focus(),50);
}
function closeModal(){document.getElementById('modalBg').classList.remove('show');}
function modalSave(){
  const v=document.getElementById('modalInput').value.trim();
  if(!v){toast('名稱不可為空','⚠️');return;}
  if(modalCtx.onSave)modalCtx.onSave(v);
  closeModal();
}
function modalDelete(){
  if(modalCtx.onDelete)modalCtx.onDelete();
  closeModal();
}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal();if(e.key==='Enter'&&document.getElementById('modalBg').classList.contains('show'))modalSave();});

