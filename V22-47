            ${['A棟','B棟','店鋪'].map((_,bi)=>`<th style="padding:4px 8px;text-align:center;border:1px solid var(--border);font-size:10px;color:var(--text3)">地主</th><th style="padding:4px 8px;text-align:center;border:1px solid var(--border);font-size:10px;color:var(--text3)">自購</th><th style="padding:4px 8px;text-align:center;border:1px solid var(--border);font-size:10px;color:var(--text3)">業主</th>`).join('')}
