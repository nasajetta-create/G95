  setTimeout(()=>document.getElementById('auth-code-inp').focus(),50);
}
function confirmClearChangelog(){
  const inp=document.getElementById('auth-code-inp');
  const code=inp?inp.value.trim():'';
  if(code!=='MONGA'){
    const err=document.getElementById('auth-error');
    if(err)err.textContent='認證碼錯誤，請重新輸入。';
    if(inp){inp.value='';inp.focus();}
    return;
  }
  document.getElementById('auth-modal').remove();
  S.changelog=[];save();renderChangelog();
  toast('更新紀錄已清除','🗑');
}
function printChangelogTable(){
  const log=S.changelog||[];
  const fmtTs=iso=>{if(!iso)return'—';const d=new Date(iso);const p=n=>String(n).padStart(2,'0');return`${d.getFullYear()}/${p(d.getMonth()+1)}/${p(d.getDate())} ${p(d.getHours())}:${p(d.getMinutes())}:${p(d.getSeconds())}`;};
  const rHTML=log.map(c=>`<tr><td>${fmtTs(c.ts)}</td><td>${esc(c.type)}</td><td>${esc(c.detail)}</td><td style="text-align:center">${c.rowCount??'—'}</td></tr>`).join('');
  printSection('更新紀錄',`<table><thead><tr><th>日期時間</th><th>類型</th><th>內容說明</th><th>總筆數</th></tr></thead><tbody>${rHTML}</tbody></table>`);
}

// ── Tabs ──────────────────────────────────────────────────────────────────
const TAB_DEFS={
  events:    {label:'📌 進度里程碑',       row:1},
  main:      {label:'📋 追蹤總表',         row:1},
  zones:     {label:'🗂 分區工作表',       row:1},
  vendor:    {label:'🏢 廠商分類',         row:1},
  warn:      {label:'⚠️ 預警看板',         row:2},
  cal:       {label:'📅 雙週行事曆',       row:2},
  mgr:       {label:'👤 管理人員',         row:2},
  done:      {label:'✅ 已完成工作',       row:2},
  handover:  {label:'🏠 交屋狀態表',      row:3},
  hstats:    {label:'📊 客戶交屋狀態表',  row:3},
  hcal:      {label:'📆 交屋行事曆',      row:3},
  pubarea:   {label:'🏛 公設狀態表',      row:3},
  clients:   {label:'👥 客戶清單',         row:3},
  changelog: {label:'📝 更新紀錄',         row:3},
};
function renderTabBar(){
  const order=S.tabOrder.filter(id=>TAB_DEFS[id]);
  const row1=order.filter(id=>TAB_DEFS[id].row===1);
  const row2=order.filter(id=>TAB_DEFS[id].row===2);
  const row3=order.filter(id=>TAB_DEFS[id].row===3);
  const makeTab=id=>`<button class="tab${id===activeTab?' active':''}" data-id="${id}"
    draggable="true"
    ondragstart="tabDragStart(event,'${id}')"
    ondragover="tabDragOver(event,'${id}')"
    ondrop="tabDrop(event,'${id}')"
    ondragleave="document.querySelectorAll('.tab').forEach(t=>t.classList.remove('tab-drag-over'))"
    onclick="switchTab('${id}')">${TAB_DEFS[id].label}</button>`;
  document.getElementById('tab-bar').innerHTML=
    `<div class="tab-row-1">${row1.map(makeTab).join('')}</div>`+
    `<div class="tab-row-2">${row2.map(makeTab).join('')}</div>`+
    `<div class="tab-row-3">${row3.map(makeTab).join('')}</div>`;
}
function switchTab(id){
  activeTab=id;
  const mc=document.getElementById('mainCard');
  mc.className='card '+(TAB_BG[id]||'card-main');
  // 先切換顯示（讓瀏覽器立即重繪），再非同步 render 避免阻塞 UI
  Object.keys(TAB_DEFS).forEach(t=>{
    const el=document.getElementById('pane-'+t);
    if(el)el.style.display=t===id?'':'none';
  });
  renderTabBar();
  // 使用 requestAnimationFrame 確保 display 變更先繪製，再執行 render
  requestAnimationFrame(()=>requestAnimationFrame(()=>renderPane(id)));
}
function renderPane(id){
  if(id==='main')renderMain();
  else if(id==='vendor')renderVendor();
  else if(id==='warn')renderWarn();
  else if(id==='cal')renderCal();
  else if(id==='zones')renderZones();
  else if(id==='mgr')renderMgr();
  else if(id==='events')renderEvents();
  else if(id==='done')renderDone();
  else if(id==='changelog')renderChangelog();
  else if(id==='handover')renderHandover();
  else if(id==='hstats')renderHStats();
  else if(id==='clients')renderClients();
  else if(id==='hcal')renderHCal();
  else if(id==='pubarea')renderPubArea();
}
function renderAll(){renderPane(activeTab);}

// ── 使用人數偵測（BroadcastChannel + localStorage） ──────────────────────
(function(){
  const CH='tracker_presence';
  const ID=Math.random().toString(36).slice(2);
  const KEY='tracker_presence_tabs';
  let peers={};
  peers[ID]=Date.now();

  function updateCount(){
    const now=Date.now();
    // 移除超過 12 秒沒心跳的 peer
    Object.keys(peers).forEach(k=>{if(now-peers[k]>12000)delete peers[k];});
    const n=Object.keys(peers).length;
    const el=document.getElementById('user-count');
    if(el){el.style.display='';el.textContent='👤 '+n+' 人';}
  }

  let bc=null;
  try{
    bc=new BroadcastChannel(CH);
    bc.onmessage=e=>{
      if(e.data&&e.data.id){peers[e.data.id]=Date.now();updateCount();}
    };
  }catch(ex){/* Safari 舊版不支援，靜默略過 */}

  // 每 5 秒廣播心跳
  setInterval(()=>{
    peers[ID]=Date.now();
    if(bc)bc.postMessage({id:ID});
    updateCount();
  },5000);

  // 頁面關閉時告知其他頁
  window.addEventListener('beforeunload',()=>{
    if(bc)bc.postMessage({id:ID,leave:true});
  });

  if(bc){
    bc.addEventListener('message',e=>{
      if(e.data&&e.data.leave&&e.data.id)delete peers[e.data.id];
      updateCount();
    });
  }
  // 初始廣播一次
  setTimeout(()=>{if(bc)bc.postMessage({id:ID});updateCount();},800);
})();


async function init(){
  Object.keys(TAB_DEFS).forEach(t=>{
    const el=document.getElementById('pane-'+t);
    if(el&&t!=='main')el.style.display='none';
  });
  window._hovFloors=new Set();
  renderTabBar();renderMain();   // 先用 localStorage 畫出 UI
  await load();                  // 再從 Firebase 更新（async）
  renderTabBar();renderAll();
  startFirebaseListen();
}

// 若 Firebase module 已分派 ready 事件，直接啟動；否則等最多 3 秒
if(window._fbReady){
  init();
} else {
  const _initTimer=setTimeout(()=>{
    setSyncStatus('offline');
    init();
  }, 3000);
  document.addEventListener('firebase-ready',()=>{
    clearTimeout(_initTimer);
    init();
  },{once:true});
  // 先用 localStorage 畫出初始畫面，不讓使用者等白畫面
  Object.keys(TAB_DEFS).forEach(t=>{if(t!=='main')document.getElementById('pane-'+t).style.display='none';});
  try{const s=localStorage.getItem(SK);if(s){const d=JSON.parse(s);if(d&&d.rows)S=migrateState(d);}}catch(e){}
  renderTabBar();renderMain();
}
</script>
