function renderChangelog(){
  const log=S.changelog||[];
  const fmtTs=iso=>{
    if(!iso)return'—';
    const d=new Date(iso);
    const pad=n=>String(n).padStart(2,'0');
    return`${d.getFullYear()}/${pad(d.getMonth()+1)}/${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
  };
  const typeColor={
    '➕ 新增項目':'var(--green)','🗑 刪除項目':'var(--red)','🗑 批次刪除':'var(--red)',
    '📂 Excel 匯入':'var(--purple)','📄 PDF 匯入':'var(--purple)',
    '📂 提示事項匯入':'#0F6E56','✏️ 欄位更新':'var(--text2)',
    '🔢 重新編號':'var(--blue)','✅ 移至完成':'var(--green)'
  };
  const rows=log.map(c=>{
    const col=typeColor[c.type]||'var(--text2)';
    return`<tr>
      <td style="white-space:nowrap;color:var(--text2);font-size:11px">${fmtTs(c.ts)}</td>
      <td><span style="font-size:11px;font-weight:600;color:${col}">${esc(c.type)}</span></td>
      <td style="font-size:11px">${esc(c.detail)}</td>
      <td style="text-align:center;font-size:11px;color:var(--text3)">${c.rowCount??'—'}</td>
    </tr>`;
  }).join('');
  const empty=!log.length?'<tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text3)">尚無更新紀錄</td></tr>':'';
  document.getElementById('pane-changelog').innerHTML=`
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap">
      <span style="font-size:14px;font-weight:700">📝 更新紀錄</span>
